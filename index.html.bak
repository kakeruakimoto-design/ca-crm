const TODAY = '2026-05-06';
const CURRENT_MONTH = '2026-04';


const { useState, useEffect, useCallback, useMemo, useRef } = React;

// ====== UTILITY ======
const fmt = (n) => n?.toLocaleString('ja-JP') ?? '0';
const fmtYen = (n) => '¥' + fmt(n);
const fmtMD = (dateStr) => {
  if (!dateStr) return '—';
  const m = (dateStr || '').match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (!m) return dateStr;
  return `${parseInt(m[2])}/${parseInt(m[3])}`;
};
const pct = (a, b) => b > 0 ? Math.round((a / b) * 100) : 0;
const clamp = (v, min, max) => Math.max(min, Math.min(max, v));

function getStatusColor(status) {
  const map = {
    '承諾': '#059669', '内定': '#0891b2', 'ブリッジ成功': '#7c3aed',
    '企業面接2': '#2563eb', '企業面接1': '#3b82f6', '推薦': '#8b5cf6',
    '企業提案': '#0d9488', '初回面接': '#f97316', '面接設定': '#f59e0b', '応募受付中': '#6b7280',
    '面接確定返信待ち': '#d97706', '選考中': '#0284c7',
    '飛び': '#dc2626', '辞退': '#9ca3af', '見送り': '#7c3aed',
  };
  return map[status] || '#6b7280';
}

function getStatusBg(status) {
  const map = {
    '承諾': '#ecfdf5', '内定': '#ecfeff', 'ブリッジ成功': '#f5f3ff',
    '企業面接2': '#eff6ff', '企業面接1': '#eff6ff', '推薦': '#f5f3ff',
    '企業提案': '#f0fdfa', '初回面接': '#fff7ed', '面接設定': '#fffbeb', '応募受付中': '#f9fafb',
    '面接確定返信待ち': '#fffbeb', '選考中': '#f0f9ff',
    '飛び': '#fef2f2', '辞退': '#f9fafb', '見送り': '#f5f3ff',
  };
  return map[status] || '#f9fafb';
}

// ====== THEME SWITCHER ======
function ThemeSwitcher({ theme, setTheme }) {
  const themes = [
    { key: 'minimal-light', color: '#2563eb', label: 'Minimal Light' },
    { key: 'executive-dark', color: '#0a0f1e', label: 'Executive Dark' },
    { key: 'soft-modern', color: '#0891b2', label: 'Soft Modern' },
  ];
  return (
    <div className="theme-switcher" title="UIテーマ切替">
      {themes.map(t => (
        <div
          key={t.key}
          className={`theme-btn ${theme === t.key ? 'active' : ''}`}
          style={{ background: t.color }}
          title={t.label}
          onClick={() => setTheme(t.key)}
        />
      ))}
    </div>
  );
}

// ====== KPI CARD ======
function KPICard({ label, value, target, color, isRate = false, suffix = '', lowerIsBetter = false, monthRatio = null }) {
  const rate = pct(value, target);
  const good = lowerIsBetter ? value <= target * 0.3 : rate >= 90;
  const warn = lowerIsBetter ? (value > target * 0.3 && value <= target * 0.6) : (rate >= 60 && rate < 90);
  const bad = lowerIsBetter ? value > target * 0.6 : rate < 60;
  const badgeText = good ? '良好' : warn ? '注意' : '要改善';
  const badgeClass = good ? 'good' : warn ? 'warn' : 'bad';
  const displayValue = isRate ? `${value}%` : `${value}${suffix}`;
  // 本日必要数・本日達成率
  const todayNeeded = (monthRatio && target) ? target * monthRatio : null;
  const todayAchRate = (todayNeeded && todayNeeded > 0) ? Math.round(value / todayNeeded * 100) : null;
  const todayColor = todayAchRate == null ? '' : todayAchRate >= 100 ? 'var(--success)' : todayAchRate >= 70 ? 'var(--warning)' : 'var(--danger)';
  const todayNeededDisp = todayNeeded != null ? (Number.isInteger(todayNeeded) ? todayNeeded : todayNeeded.toFixed(1)) : null;
  return (
    <div className="kpi-card" style={{'--kpi-color': color}}>
      <div className="kpi-label">{label}</div>
      <div className="kpi-value">{displayValue}</div>
      <div className="kpi-target">目標: {isRate ? `${target}%` : `${target}${suffix}`}</div>
      <div className="kpi-progress">
        <div className="kpi-progress-fill" style={{width: `${clamp(lowerIsBetter ? 100 - pct(value, target) : rate, 0, 100)}%`}} />
      </div>
      <span className={`kpi-badge ${badgeClass}`}>{badgeText} {isRate ? '' : `${rate}%`}</span>
      {todayNeededDisp !== null && (
        <div style={{fontSize:'12px', color:'var(--text-muted)', marginTop:'4px'}}>
          本日必要数: {todayNeededDisp}件
        </div>
      )}
      {todayAchRate !== null && (
        <div style={{fontSize:'12px', fontWeight:'700', color: todayColor, marginTop:'2px'}}>
          本日達成率 {todayAchRate}%
        </div>
      )}
    </div>
  );
}

// ====== DONUT KPI CARD ======
function DonutKPICard({ label, value, target, color, monthRatio = null, lowerIsBetter = false }) {
  const displayRate = target > 0 ? Math.round(value / target * 100) : 0;
  const fillRate    = Math.min(displayRate, 100);
  // lowerIsBetter（飛び+辞退など）は値が低いほど良い
  const good = lowerIsBetter ? displayRate <= 50  : displayRate >= 90;
  const warn = lowerIsBetter ? displayRate <= 80  : (displayRate >= 60 && displayRate < 90);
  const badgeText  = good ? '良好' : warn ? '注意' : '要改善';
  const badgeColor = good ? 'var(--success)' : warn ? 'var(--warning)' : 'var(--danger)';
  const badgeBg    = good ? 'var(--success-bg)' : warn ? 'var(--warning-bg)' : 'var(--danger-bg)';

  // SVG donut
  const size = 96;
  const sw   = 10;
  const r    = (size - sw) / 2;
  const circ = 2 * Math.PI * r;
  const filled = circ * fillRate / 100;

  // 本日必要数・本日達成率
  const todayNeeded    = (monthRatio && target) ? target * monthRatio : null;
  const todayAchRate   = (todayNeeded && todayNeeded > 0) ? Math.round(value / todayNeeded * 100) : null;
  const todayColor     = todayAchRate == null ? '' : todayAchRate >= 100 ? 'var(--success)' : todayAchRate >= 70 ? 'var(--warning)' : 'var(--danger)';
  const todayNeededDisp = todayNeeded != null ? (Number.isInteger(todayNeeded) ? todayNeeded : todayNeeded.toFixed(1)) : null;

  return (
    <div style={{
      background:'var(--bg-card)', border:'1px solid var(--border)',
      borderRadius:'var(--radius)', padding:'12px 8px 10px',
      boxShadow:'var(--shadow)', display:'flex', flexDirection:'column',
      alignItems:'center', gap:'5px', position:'relative', overflow:'hidden',
    }}>
      <div style={{position:'absolute',top:0,left:0,right:0,height:'3px',background:color}}/>
      <div style={{fontSize:'12px',color:'var(--text-muted)',fontWeight:'600',textTransform:'uppercase',letterSpacing:'0.5px',textAlign:'center'}}>{label}</div>
      {/* Donut SVG */}
      <div style={{position:'relative',width:`${size}px`,height:`${size}px`}}>
        <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} style={{transform:'rotate(-90deg)'}}>
          <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="var(--border)" strokeWidth={sw}/>
          <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={color} strokeWidth={sw}
            strokeDasharray={`${filled} ${circ}`} strokeLinecap="round"/>
        </svg>
        <div style={{position:'absolute',inset:0,display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',gap:'1px'}}>
          <div style={{fontSize:'26px',fontWeight:'800',color:'var(--text-primary)',lineHeight:1}}>{value}</div>
          <div style={{fontSize:'12px',color:'var(--text-muted)'}}>/ {target}</div>
        </div>
      </div>
      <span style={{fontSize:'12px',fontWeight:'700',padding:'2px 8px',borderRadius:'10px',background:badgeBg,color:badgeColor}}>
        {badgeText} {displayRate}%
      </span>
      {todayNeededDisp !== null && (
        <div style={{fontSize:'12px',color:'var(--text-muted)',textAlign:'center'}}>本日必要数: {todayNeededDisp}件</div>
      )}
      {todayAchRate !== null && (
        <div style={{fontSize:'12px',fontWeight:'700',color:todayColor,textAlign:'center'}}>本日達成率 {todayAchRate}%</div>
      )}
    </div>
  );
}

// ====== RATE KPI CARD ======
function RateKPICard({ label, value, target, numerator, denominator, lowerIsBetter = false, denominatorLabel = null }) {
  const good = lowerIsBetter ? value <= target * 0.5 : value >= target;
  const warn = lowerIsBetter ? (value > target * 0.5 && value <= target) : (value >= target * 0.7 && value < target);
  const bad = lowerIsBetter ? value > target : value < target * 0.7;
  const evalClass = good ? 'eval-good' : warn ? 'eval-warn' : 'eval-bad';
  const evalText = good ? '良好' : warn ? '注意' : '要改善';
  const color = good ? 'var(--success)' : warn ? 'var(--warning)' : 'var(--danger)';
  const gaugeWidth = clamp(lowerIsBetter ? (1 - value/100)*100 : (value/target)*100, 0, 100);
  return (
    <div className="rate-kpi-card">
      <div className="rate-kpi-label">{label}</div>
      <div className="rate-kpi-value" style={{color}}>{value}%</div>
      <div className="rate-kpi-detail">{numerator}件 / {denominatorLabel || `${denominator}件`}</div>
      <div className="rate-kpi-gauge">
        <div className="rate-kpi-gauge-fill" style={{width: `${gaugeWidth}%`, background: color}} />
      </div>
      <div className="rate-kpi-meta">
        <span className="text-muted" style={{fontSize:'14px'}}>目標: {target}%</span>
        <span className={`eval-badge ${evalClass}`}>{evalText}</span>
      </div>
    </div>
  );
}

// ====== DONUT CHART ======
function DonutChart({ value, target, requiredByToday, current, size = 140 }) {
  const rate = pct(current, target);
  const reqRate = pct(requiredByToday, target);
  const r = 52;
  const circumference = 2 * Math.PI * r;
  const fillDash = (clamp(rate, 0, 100) / 100) * circumference;
  const reqDash = (clamp(reqRate, 0, 100) / 100) * circumference;
  const color = rate >= reqRate ? 'var(--success)' : rate >= reqRate * 0.7 ? 'var(--warning)' : 'var(--danger)';
  const diff = current - requiredByToday;
  return (
    <div className="donut-container">
      <svg width={size} height={size} viewBox="0 0 120 120">
        <circle cx="60" cy="60" r={r} fill="none" stroke="var(--donut-track)" strokeWidth="12"/>
        {reqRate > 0 && (
          <circle cx="60" cy="60" r={r} fill="none" stroke="var(--border)" strokeWidth="12"
            strokeDasharray={`${reqDash} ${circumference}`} strokeLinecap="round"
            transform="rotate(-90 60 60)" opacity="0.4"/>
        )}
        <circle cx="60" cy="60" r={r} fill="none" stroke={color} strokeWidth="12"
          strokeDasharray={`${fillDash} ${circumference}`} strokeLinecap="round"
          transform="rotate(-90 60 60)" style={{transition:'stroke-dasharray 0.8s ease'}}/>
        <text x="60" y="55" textAnchor="middle" fill="var(--text-primary)" fontSize="18" fontWeight="700">{rate}%</text>
        <text x="60" y="70" textAnchor="middle" fill="var(--text-muted)" fontSize="9">受注進捗</text>
      </svg>
      <div className="donut-stats">
        <div className="donut-stat">
          <span className="donut-stat-label">目標金額</span>
          <span className="donut-stat-value">{fmtYen(target)}</span>
        </div>
        <div className="donut-stat">
          <span className="donut-stat-label">本日必要額</span>
          <span className="donut-stat-value">{fmtYen(requiredByToday)}</span>
        </div>
        <div className="donut-stat">
          <span className="donut-stat-label">現状金額</span>
          <span className="donut-stat-value" style={{color}}>{fmtYen(current)}</span>
        </div>
        <div className="separator"/>
        <div className="donut-stat">
          <span className="donut-stat-label">必要ペース差</span>
          <span className="donut-stat-value" style={{color: diff >= 0 ? 'var(--success)' : 'var(--danger)'}}>
            {diff >= 0 ? '+' : ''}{fmtYen(diff)}
          </span>
        </div>
      </div>
    </div>
  );
}

// ====== FUNNEL CHART (SVG) ======
function FunnelChart({ data }) {
  const max = data[0]?.value || 1;
  const W = 200, minW = 40, barH = 28, gap = 4;
  const totalH = data.length * (barH + gap);
  return (
    <svg width="100%" viewBox={`0 0 ${W} ${totalH}`} style={{overflow:'visible'}}>
      {data.map((d, i) => {
        const w = minW + (W - minW) * (d.value / max);
        const x = (W - w) / 2;
        const y = i * (barH + gap);
        const retentionRate = Math.round((d.value / max) * 100);
        return (
          <g key={i}>
            <rect x={x} y={y} width={w} height={barH}
              fill={`var(--funnel-fill)`} opacity={1 - i * 0.08} rx="3"/>
            <text x={W/2} y={y + barH/2 + 1} textAnchor="middle"
              fill="white" fontSize="10" fontWeight="600" dominantBaseline="middle">
              {d.label} {d.value}件
            </text>
            <text x={x + w + 6} y={y + barH/2 + 1} textAnchor="start"
              fill="var(--text-muted)" fontSize="9" dominantBaseline="middle">
              {retentionRate}%
            </text>
          </g>
        );
      })}
    </svg>
  );
}

// ====== LINE CHART (SVG) ======
function LineChart({ datasets, labels, height = 140 }) {
  const W = 320, H = height, padL = 36, padR = 10, padT = 10, padB = 28;
  const chartW = W - padL - padR;
  const chartH = H - padT - padB;
  const allVals = datasets.flatMap(d => d.data);
  const maxV = Math.max(...allVals, 1);
  const xs = labels.map((_, i) => padL + (i / (labels.length - 1)) * chartW);
  const ys = (data) => data.map(v => padT + chartH - (v / maxV) * chartH);
  const pathD = (data) => {
    const pts = xs.map((x, i) => ({ x, y: ys(data)[i] }));
    return pts.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
  };
  const colors = ['var(--chart-1)', 'var(--chart-3)', 'var(--chart-4)', 'var(--chart-2)', 'var(--chart-5)'];
  return (
    <svg width="100%" viewBox={`0 0 ${W} ${H}`}>
      {[0, 0.25, 0.5, 0.75, 1].map((t, i) => {
        const y = padT + chartH - t * chartH;
        return (
          <g key={i}>
            <line x1={padL} y1={y} x2={W - padR} y2={y} stroke="var(--border)" strokeWidth="1"/>
            <text x={padL - 4} y={y + 1} textAnchor="end" fill="var(--text-muted)" fontSize="8" dominantBaseline="middle">
              {Math.round(maxV * t)}
            </text>
          </g>
        );
      })}
      {labels.map((l, i) => (
        <text key={i} x={xs[i]} y={H - padB + 12} textAnchor="middle"
          fill="var(--text-muted)" fontSize="8">{l}</text>
      ))}
      {datasets.map((ds, di) => (
        <path key={di} d={pathD(ds.data)}
          fill="none" stroke={colors[di]} strokeWidth="2" strokeLinejoin="round"/>
      ))}
      {datasets.map((ds, di) => 
        xs.map((x, i) => (
          <circle key={`${di}-${i}`} cx={x} cy={ys(ds.data)[i]} r="3"
            fill={colors[di]} stroke="var(--bg-card)" strokeWidth="2"/>
        ))
      )}
      <g transform={`translate(${padL},${H})`}>
        {datasets.map((ds, di) => (
          <g key={di} transform={`translate(${di * 70}, 0)`}>
            <line x1="0" y1="0" x2="12" y2="0" stroke={colors[di]} strokeWidth="2"/>
            <text x="15" y="1" fill="var(--text-muted)" fontSize="8" dominantBaseline="middle">{ds.label}</text>
          </g>
        ))}
      </g>
    </svg>
  );
}

// ====== HORIZONTAL BAR CHART ======
function HBarChart({ data, valueFormatter }) {
  const max = Math.max(...data.map(d => d.value), 1);
  return (
    <div style={{display:'flex', flexDirection:'column', gap:'6px'}}>
      {data.map((d, i) => {
        const pct = (d.value / max) * 100;
        return (
          <div key={i} style={{display:'flex', alignItems:'center', gap:'8px'}}>
            <div style={{width:'72px', fontSize:'15px', color:'var(--text-secondary)', textAlign:'right', flexShrink:0}}>{d.label}</div>
            <div style={{flex:1, height:'16px', background:'var(--border)', borderRadius:'3px', overflow:'hidden'}}>
              <div style={{
                width:`${pct}%`, height:'100%',
                background: d.color || 'var(--bar-fill)',
                borderRadius:'3px', transition:'width 0.6s ease',
                display:'flex', alignItems:'center', justifyContent:'flex-end', paddingRight:'4px'
              }}>
                {pct > 25 && <span style={{fontSize:'11px', color:'white', fontWeight:'600'}}>{valueFormatter ? valueFormatter(d.value) : d.value}</span>}
              </div>
            </div>
            {pct <= 25 && <span style={{fontSize:'14px', color:'var(--text-secondary)', minWidth:'40px'}}>{valueFormatter ? valueFormatter(d.value) : d.value}</span>}
          </div>
        );
      })}
    </div>
  );
}

// ====== STATUS BADGE ======
function StatusBadge({ status }) {
  return (
    <span className="status-badge" style={{
      background: getStatusBg(status),
      color: getStatusColor(status),
    }}>{status}</span>
  );
}

// ====== PROGRESS TABLE COMPONENT ======
function ProgressTableSection({ data, showTodayTarget, isCurrentMonth = true }) {
  // 本日時点での必要数値を計算
  const now = new Date();
  const year = now.getFullYear();
  const month = now.getMonth();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const dayOfMonth = now.getDate();
  const todayRatio = dayOfMonth / daysInMonth;

  return (
    <table className="progress-table">
      <thead>
        <tr>
          <th>ステージ</th>
          <th className="num" style={{color:'var(--text-muted)'}}>目標</th>
          {showTodayTarget && <th className="num" style={{color:'var(--accent)'}}>{isCurrentMonth ? '本日目標' : '月末目標'}</th>}
          <th className="num">実績</th>
          {showTodayTarget && <th className="num" style={{color:'var(--accent)'}}>{isCurrentMonth ? '日次達成率' : '月末達成率'}</th>}
          <th className="num">全体達成率</th>
          <th style={{width:'120px'}}>進捗</th>
        </tr>
      </thead>
      <tbody>
        {data.map((row, i) => {
          const lb = !!row.lowerIsBetter;
          const totalRate = pct(row.actual, row.target);
          const todayTarget = showTodayTarget ? Math.ceil(row.target * todayRatio) : null;
          const todayRate = showTodayTarget ? pct(row.actual, todayTarget) : null;
          const totalColor = lb
            ? (totalRate <= 50 ? 'var(--success)' : totalRate <= 80 ? 'var(--warning)' : 'var(--danger)')
            : (totalRate >= 90 ? 'var(--success)' : totalRate >= 60 ? 'var(--warning)' : 'var(--danger)');
          const todayColor = todayRate == null ? null : lb
            ? (todayRate <= 50 ? 'var(--success)' : todayRate <= 80 ? 'var(--warning)' : 'var(--danger)')
            : (todayRate >= 100 ? 'var(--success)' : todayRate >= 70 ? 'var(--warning)' : 'var(--danger)');
          const barColor = lb ? (totalRate <= 50 ? 'var(--success)' : totalRate <= 80 ? 'var(--warning)' : 'var(--danger)') : totalColor;
          return (
            <tr key={i} style={lb ? {background:'var(--bg-hover)'} : {}}>
              <td style={{fontWeight:'500'}}>
                {row.stage}{lb ? ' ↓' : ''}
                {row.carryOver > 0 && row.stage === '承諾' && (
                  <span style={{fontSize:'11px',color:'var(--accent)',marginLeft:'4px',fontWeight:'400'}}>（うち持越{row.carryOver}件）</span>
                )}
              </td>
              <td className="num" style={{color:'var(--text-muted)'}}>{row.target}{lb ? '以下' : ''}</td>
              {showTodayTarget && <td className="num" style={{color:'var(--accent)', fontWeight:'600'}}>{todayTarget}</td>}
              <td className="num" style={{fontWeight:'700'}}>{row.actual}</td>
              {showTodayTarget && (
                <td className="num" style={{color:todayColor, fontWeight:'700'}}>
                  {todayRate}%
                </td>
              )}
              <td className="num" style={{color:totalColor, fontWeight:'700'}}>{totalRate}%</td>
              <td>
                <div className="stage-bar">
                  <div className="stage-bar-fill" style={{width:`${clamp(totalRate,0,100)}%`, background:barColor}} />
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  );
}


// ====== INDIVIDUAL DASHBOARD APP ======
// 管理者が設定した目標を localStorage から読み込む
let CA_MY_NAME = 'テストCA'; // テストモード固定
const _DR = { firstInterview:80, bridge:50, proposal:75, recommendation:60, companyInterview:67, offer:50, acceptance:50 };
function _readGoals() {
  try {
    const allGoals = JSON.parse(localStorage.getItem('test-crm-goals')||'{}');
    const now = new Date();
    const monthKey = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
    return allGoals[`${CA_MY_NAME}_${monthKey}`] || allGoals[CA_MY_NAME] || null;
  } catch { return null; }
}
// 目標値は _calcRealMetrics() 内で動的に計算されます

const TREND_DATA = {
  labels: ['4/1', '4/8', '4/15', '4/22', '4/29', '5/6'],
  datasets: [
    { label: '応募', data: [3, 7, 11, 15, 19, 21] },
    { label: '面接設定', data: [2, 5, 8, 11, 14, 16] },
    { label: '内定', data: [0, 0, 1, 1, 2, 2] },
  ],
};

// リアルデータからKPI指標を計算するヘルパー関数
// period: "YYYY/MM" 形式（例 "2026/05"）。指定された月の firstInterviewDate を持つ候補者のみ集計。
function _calcRealMetrics(candidates, period) {
  // 各ステージを「アクションが発生した月」でカウントする方式
  // 例：4月推薦→5月企業面接 の人は 推薦=4月カウント、企業面接=5月カウント
  const periodKey = period ? period.replace('/', '-') : null;
  const pk = periodKey; // e.g., "2026-04"

  const DR = { firstInterview:80, bridge:50, proposal:75, recommendation:60, companyInterview:67, offer:50, acceptance:50 };
  let goals = null;
  try {
    const allGoals = JSON.parse(localStorage.getItem('test-crm-goals')||'{}');
    const now = new Date();
    const monthKey = pk || `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
    goals = allGoals[`${CA_MY_NAME}_${monthKey}`] || allGoals[CA_MY_NAME] || null;
  } catch {}
  const gs = goals?.settings || 25;
  const gr = goals?.rates || DR;

  // 目標値を計算（gs=面接設定目標, gFI=初回面接目標）
  const gFI  = Math.round(gs  * (gr.firstInterview   || 80) / 100);
  const gBR  = Math.round(gFI  * (gr.bridge           || 50) / 100);
  const gPR  = Math.round(gBR  * (gr.proposal         || 75) / 100);
  const gREC = Math.round(gPR  * (gr.recommendation   || 60) / 100);
  const gCI  = Math.round(gREC * (gr.companyInterview || 67) / 100);
  const gOF  = Math.round(gCI  * (gr.offer            || 50) / 100);
  const gAC  = Math.round(gOF  * (gr.acceptance       || 50) / 100);
  const gFly = Math.max(1, Math.round(gFI * 0.15));

  const _todayStr = new Date().toISOString().slice(0, 10);

  // ─── 各ステージを日付フィールドでカウント（全候補者を対象） ───

  // 面接設定: createdAt（登録日）がこの月
  const aFI = pk
    ? candidates.filter(c => (c.createdAt||c.firstInterviewDate||'').slice(0,7) === pk).length
    : candidates.length;

  // 初回面接: firstInterviewDate がこの月 かつ 過去（≤今日）かつ 面接設定でない（未実施でない）
  const aINT = pk
    ? candidates.filter(c => {
        const fid = (c.firstInterviewDate||'').slice(0,10);
        const st = c.caStatus||c.status;
        return fid.startsWith(pk) && fid <= _todayStr && st !== '面接設定' && st !== '飛び(辞退)';
      }).length
    : candidates.filter(c => { const st=c.caStatus||c.status; return !!c.firstInterviewDate && st !== '面接設定' && st !== '飛び(辞退)'; }).length;

  // 飛び+辞退: firstInterviewDate がこの月 かつ 飛び(辞退)
  const aFly = pk
    ? candidates.filter(c => {
        const fid = (c.firstInterviewDate||'').slice(0,10);
        return fid.startsWith(pk) && fid <= _todayStr && (c.caStatus||c.status) === '飛び(辞退)';
      }).length
    : candidates.filter(c => (c.caStatus||c.status) === '飛び(辞退)').length;

  // ブリッジ成功: bridgeDate がこの月 かつ bridgeResult='成功'
  const aBR = pk
    ? candidates.filter(c => {
        const bd = (c.bridgeDate||'').slice(0,10);
        return bd.startsWith(pk) && bd <= _todayStr && c.bridgeResult === '成功';
      }).length
    : candidates.filter(c => c.bridgeResult === '成功').length;

  // 企業提案: proposalDate がこの月
  const aPR = pk
    ? candidates.filter(c => {
        const pd = (c.proposalDate||'').slice(0,10);
        return pd.startsWith(pk) && pd <= _todayStr;
      }).length
    : candidates.filter(c => !!c.proposalDate).length;

  // 推薦: recommendationDate がこの月
  const aREC = pk
    ? candidates.filter(c => {
        const rd = (c.recommendationDate||'').slice(0,10);
        return rd.startsWith(pk) && rd <= _todayStr;
      }).length
    : candidates.filter(c => !!c.recommendationDate).length;

  // 企業面接: companyInterviewDate がこの月（専用フィールド）
  const aCI = pk
    ? candidates.filter(c => {
        const cd = (c.companyInterviewDate||'').slice(0,10);
        return cd.startsWith(pk) && cd <= _todayStr;
      }).length
    : candidates.filter(c => !!c.companyInterviewDate).length;

  // 内定: offerDate がこの月
  const aOF = pk
    ? candidates.filter(c => {
        const od = (c.offerDate||'').slice(0,10);
        return od.startsWith(pk) && od <= _todayStr;
      }).length
    : candidates.filter(c => !!c.offerDate).length;

  // 承諾: crm-accepted の acceptedAt がこの月
  let aAC = 0;
  let aCO_AC = 0;
  try {
    const _allAcc = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
    const myAcc = _allAcc.filter(a => a.assignedCA === CA_MY_NAME);
    if (pk) {
      const thisAcc = myAcc.filter(a => {
        const ad = (a.acceptedAt||'').slice(0,10);
        return ad.startsWith(pk) && ad <= _todayStr;
      });
      aAC = thisAcc.length;
      // 持ち越し承諾: 今月承諾 AND firstInterviewDate が前月以前
      aCO_AC = thisAcc.filter(a => {
        const cand = candidates.find(c => c.id === a.id);
        const fid = (cand?.firstInterviewDate || '').slice(0, 7);
        return fid && fid < pk;
      }).length;
    } else {
      aAC = myAcc.length;
    }
  } catch {}

  // 有効候補者数（登録月の候補者のうち飛び以外）
  const ENDED_ST = ['飛び(辞退)', '見送り'];
  const aVA = pk
    ? candidates.filter(c => (c.createdAt||c.firstInterviewDate||'').slice(0,7) === pk && !ENDED_ST.includes(c.caStatus||c.status)).length
    : candidates.filter(c => !ENDED_ST.includes(c.caStatus||c.status)).length;

  // 飛び率計算（初回+飛び の合計を分母）
  const flyDenom = aINT + aFly;
  const pastFly = aFly;
  const flyRateToday = flyDenom > 0 ? Math.round(aFly / flyDenom * 100) : 0;

  const kpi = {
    validApplications:  { value: aVA,  target: null },
    interviewSet:       { value: aFI,  target: gs   },
    flyDropout:         { value: aFly, target: gFly, lowerIsBetter: true },
    initialInterview:   { value: aINT, target: gFI  },
    bridgeSuccess:      { value: aBR,  target: gBR  },
    proposal:           { value: aPR,  target: gPR  },
    recommendation:     { value: aREC, target: gREC },
    companyInterview:   { value: aCI,  target: gCI  },
    offer:              { value: aOF,  target: gOF  },
    acceptance:         { value: aAC,  target: gAC  },
  };

  const stageProgress = [
    { stage: '面接設定',    actual: aFI,  target: gs,   lowerIsBetter: false },
    { stage: '飛び+辞退',  actual: aFly, target: gFly, lowerIsBetter: true  },
    { stage: '初回面接',    actual: aINT, target: gFI,  lowerIsBetter: false },
    { stage: 'ブリッジ成功', actual: aBR,  target: gBR,  lowerIsBetter: false },
    { stage: '企業提案',    actual: aPR,  target: gPR,  lowerIsBetter: false },
    { stage: '推薦',        actual: aREC, target: gREC, lowerIsBetter: false },
    { stage: '企業面接',    actual: aCI,  target: gCI,  lowerIsBetter: false },
    { stage: '内定',        actual: aOF,  target: gOF,  lowerIsBetter: false },
    { stage: '承諾',        actual: aAC,  target: gAC,  lowerIsBetter: false, carryOver: aCO_AC },
  ];

  const rateKpis = [
    // 飛び率：飛び ÷ (初回面接 + 飛び) × 100
    { label: '飛び率',     value: flyRateToday,
      target: 15,  numerator: pastFly, denominator: flyDenom, lowerIsBetter: true,
      denominatorLabel: `初回+飛び(${flyDenom}件)` },
    // ブリッジ率：初回面接 → ブリッジ成功
    { label: 'ブリッジ率', value: aINT > 0 ? Math.round(aBR/aINT*100) : 0,
      target: gr.bridge||50,       numerator: aBR,  denominator: aINT, lowerIsBetter: false },
    // 企業提案率：ブリッジ成功 → 企業提案
    { label: '企業提案率', value: aBR > 0 ? Math.round(aPR/aBR*100) : 0,
      target: gr.proposal||75,     numerator: aPR,  denominator: aBR, lowerIsBetter: false },
    // 推薦率：企業提案 → 推薦
    { label: '推薦率',     value: aPR > 0 ? Math.round(aREC/aPR*100) : 0,
      target: gr.recommendation||60, numerator: aREC, denominator: aPR, lowerIsBetter: false },
    // 企業面接率：推薦 → 企業面接
    { label: '企業面接率', value: aREC > 0 ? Math.round(aCI/aREC*100) : 0,
      target: gr.companyInterview||67, numerator: aCI, denominator: aREC, lowerIsBetter: false },
    // 内定率：企業面接 → 内定
    { label: '内定率',     value: aCI > 0 ? Math.round(aOF/aCI*100) : 0,
      target: gr.offer||50,        numerator: aOF,  denominator: aCI, lowerIsBetter: false },
    // 承諾率：内定 → 承諾
    { label: '承諾率',     value: aOF > 0 ? Math.round(aAC/aOF*100) : 0,
      target: gr.acceptance||50,   numerator: aAC,  denominator: aOF, lowerIsBetter: false },
  ];

  const funnelData = [
    { label: '面接設定', value: aFI },
    { label: 'ブリッジ', value: aBR },
    { label: '企業提案', value: aPR },
    { label: '企業面接', value: aCI },
    { label: '内定',     value: aOF },
    { label: '承諾',     value: aAC },
  ];

  // 受注金額を crm-accepted から計算（period指定時はその月のものだけ）
  let myAccepted = [];
  try {
    const _acc = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
    let _mine = _acc.filter(a => a.assignedCA === CA_MY_NAME);
    if (pk) {
      _mine = _mine.filter(a => {
        const ad = (a.acceptedAt||'').slice(0,10);
        return ad.startsWith(pk) && ad <= _todayStr;
      });
    }
    myAccepted = _mine;
  } catch {}
  const _revCur = myAccepted.reduce((s, a) => s + (Number(a.contractAmount) || 0), 0);
  const _revTgt = goals?.targets?.revenueTarget
    || (goals?.targets?.acceptance ? goals.targets.acceptance * 500000 : null)
    || (goals?.settings ? goals.settings * 500000 : 3000000);
  // 本日必要額は当月のみ意味がある。過去月は月末時点で算出
  const _now = new Date();
  let _dayProgress, _daysInM;
  if (periodKey) {
    const [py, pm] = periodKey.split('-').map(Number);
    _daysInM = new Date(py, pm, 0).getDate();
    const isCurMonth = py === _now.getFullYear() && pm === (_now.getMonth() + 1);
    _dayProgress = isCurMonth ? _now.getDate() : _daysInM;
  } else {
    _daysInM = new Date(_now.getFullYear(), _now.getMonth() + 1, 0).getDate();
    _dayProgress = _now.getDate();
  }
  const revenue = {
    current: _revCur,
    target: _revTgt,
    requiredByToday: Math.round(_revTgt * _dayProgress / _daysInM),
  };

  return { kpi, stageProgress, rateKpis, funnelData, settings: gs, revenue };
}

function _loadMyMetrics(period) {
  try {
    const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
    const mine = Array.isArray(stored) ? stored.filter(c => c.assignedCA === CA_MY_NAME) : [];
    return _calcRealMetrics(mine, period);
  } catch { return _calcRealMetrics([], period); }
}

// 面接カード・提案中・対応事項をリアルデータから生成
function _loadSummaryData() {
  const todayStr = new Date().toISOString().slice(0, 10);
  const tomorrowStr = new Date(Date.now() + 86400000).toISOString().slice(0, 10);
  const in7DaysStr = new Date(Date.now() + 7 * 86400000).toISOString().slice(0, 10);

  let cands = [], plans = {}, accepted = [];
  try {
    const s = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
    cands = Array.isArray(s) ? s.filter(c => c.assignedCA === CA_MY_NAME) : [];
  } catch {}
  try { plans = JSON.parse(localStorage.getItem('test-crm-interview-plans') || '{}'); } catch {}
  try { accepted = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]'); } catch {}

  // 本日の初回面接（firstInterviewDate が今日）
  const interviewsFirstToday = cands
    .filter(c => (c.firstInterviewDate || '').startsWith(todayStr))
    .map(c => ({
      name: c.name,
      time: (c.firstInterviewDate || '').length > 10 ? c.firstInterviewDate.slice(11, 16) : '—',
      type: '初回面接',
    }));

  // 本日の企業面接（crm-interview-plans の今日エントリ）
  const interviewsToday = [];
  Object.entries(plans).forEach(([cid, entries]) => {
    const cand = cands.find(c => c.id === cid);
    if (!cand) return;
    (entries || []).forEach(e => {
      if ((e.date || '').startsWith(todayStr)) {
        // 書類選考中・面接確定返信待ちは今後の面接予定に含めない
        if (e.selectionStatus === '書類選考中') return;
        if (e.pendingConfirm) return;
        // 終了済み（候補者側・選考側）は除外
        const _cs = cand.caStatus || cand.status || '';
        if (['飛び(辞退)','見送り','承諾'].includes(_cs)) return;
        if (['選考辞退','書類お見送り','面接お見送り'].includes(e.selectionStatus)) return;
        interviewsToday.push({
          name: cand.name,
          company: e.company || '—',
          time: (e.date || '').length > 10 ? e.date.slice(11, 16) : '—',
          type: e.selectionStatus || '企業面接',
        });
      }
    });
  });

  // 今後7日の面接予定（明日〜7日後）
  const interviewsUpcoming = [];
  Object.entries(plans).forEach(([cid, entries]) => {
    const cand = cands.find(c => c.id === cid);
    if (!cand) return;
    (entries || []).forEach(e => {
      const d = (e.date || '').slice(0, 10);
      if (d >= tomorrowStr && d <= in7DaysStr) {
        // 書類選考中・面接確定返信待ちは今後の面接予定に含めない
        if (e.selectionStatus === '書類選考中') return;
        if (e.pendingConfirm) return;
        // 終了済みは除外
        const _cs2 = cand.caStatus || cand.status || '';
        if (['飛び(辞退)','見送り','承諾'].includes(_cs2)) return;
        if (['選考辞退','書類お見送り','面接お見送り'].includes(e.selectionStatus)) return;
        interviewsUpcoming.push({
          name: cand.name,
          company: e.company || '—',
          date: d.slice(5).replace('-', '/'),
          type: e.selectionStatus || '企業面接',
        });
      }
    });
  });
  interviewsUpcoming.sort((a, b) => a.date.localeCompare(b.date));

  // 面接確定返信待ち
  // ① 初回面接設定中で firstInterviewDate 未設定
  const pendingReply = [
    ...cands
      .filter(c => (c.caStatus || c.status || '') === '面接設定' && !c.firstInterviewDate)
      .map(c => {
        const days = c.createdAt
          ? Math.floor((Date.now() - new Date(c.createdAt).getTime()) / 86400000)
          : 0;
        return {
          name: c.name,
          memo: days > 2 ? `初回面接 確定返信待ち（${days}日経過）` : `初回面接 確定返信待ち`,
          urgent: days > 2,
        };
      }),
    // ② 企業面接管理で pendingConfirm がチェックされているエントリ
    ...(() => {
      const result = [];
      Object.entries(plans).forEach(([cid, entries]) => {
        const cand = cands.find(c => c.id === cid);
        if (!cand) return;
        const _cs3 = cand.caStatus || cand.status || '';
        if (['飛び(辞退)','見送り','承諾'].includes(_cs3)) return; // 終了済み除外
        (entries || []).forEach(e => {
          if (['選考辞退','書類お見送り','面接お見送り'].includes(e.selectionStatus)) return;
          if (e.pendingConfirm) {
            const dateStr = e.date ? e.date.slice(5,10).replace('-','/') : '日時未確定';
            result.push({
              name: cand.name,
              memo: `${e.company||'企業'} · ${dateStr} 面接確定返信待ち`,
              urgent: true,
            });
          }
        });
      });
      return result;
    })(),
  ];

  // 企業提案中: ブリッジ成功以降・承諾/見送り/飛び(辞退)でない候補者
  // 初回面接が終わった人は必ずブリッジ成功 or 終了になる（初回面接ステータスのまま止まることはない）
  const PROP_ST = ['ブリッジ成功','企業提案','推薦','面接対策１','面接対策２','企業面接','内定'];
  const proposalCandidates = cands.filter(c => {
    const cs = c.caStatus || c.status || '';
    return PROP_ST.includes(cs);
  }).map(c => {
    // 最新の提案企業をinterview plansから取得
    const cpList = plans[c.id] || [];
    const activeCompanies = cpList
      .filter(cp => !['選考辞退','書類お見送り','面接お見送り'].includes(cp.selectionStatus||''))
      .map(cp => cp.company || '').filter(Boolean);
    const latestCompany = activeCompanies[activeCompanies.length - 1] || c.companyName || '—';
    // 最新の日付（提案日→推薦日→企業面接日→内定日の順で最新を表示）
    const stageDate = c.offerDate || c.companyInterviewDate || c.recommendationDate || c.proposalDate || c.bridgeDate || '';
    return { ...c, _propCompany: latestCompany, _propDate: stageDate.slice(0,10) };
  });

  // 対応事項（ルールベースで自動生成）
  const actions = [];
  // 承諾期限アラート（カスタム日数対応）
  const _tdStr = new Date().toISOString().slice(0,10);
  Object.entries(plans).forEach(([cid, cpList]) => {
    const cand = cands.find(c => c.id === cid);
    if (!cand) return;
    (cpList || []).forEach(cp => {
      if (cp.selectionStatus === '内定' && cp.offerDeadline) {
        const dl = cp.offerDeadline.slice(5).replace('-','/');
        const daysLeft = Math.ceil((new Date(cp.offerDeadline) - new Date(_tdStr)) / 86400000);
        const alertDays = cp.alertDays !== undefined ? Number(cp.alertDays) : 3;
        if (daysLeft < 0) {
          actions.push({ priority: '高', text: `${cand.name} — ${cp.company||''}  承諾期限超過（${dl}）`, due: '至急確認', urgent: true });
        } else if (daysLeft <= alertDays) {
          const dueLabel = daysLeft === 0 ? '本日期限' : daysLeft === 1 ? '明日まで' : `あと${daysLeft}日`;
          actions.push({ priority: '高', text: `${cand.name} — ${cp.company||''}  承諾期限（${dl}）`, due: dueLabel, urgent: true });
        }
      }
    });
  });
  cands.filter(c => (c.caStatus || c.status) === '内定').forEach(c => {
    actions.push({ priority: '高', text: `${c.name} — 内定承諾確認連絡`, due: '本日中', urgent: true });
  });
  pendingReply.filter(p => p.urgent).forEach(p => {
    actions.push({ priority: '高', text: `${p.name} — 返信督促`, due: '本日中', urgent: true });
  });
  cands.filter(c => (c.caStatus || c.status) === '初回面接').forEach(c => {
    actions.push({ priority: '高', text: `${c.name} — ブリッジ確認・結果フォロー`, due: '今週中', urgent: false });
  });
  cands.filter(c => (c.caStatus || c.status) === 'ブリッジ成功').forEach(c => {
    actions.push({ priority: '中', text: `${c.name} — 企業提案・求人紹介`, due: '今週中', urgent: false });
  });
  interviewsFirstToday.forEach(iv => {
    actions.push({ priority: '中', text: `${iv.name} — 初回面接後ブリッジ確認`, due: '本日中', urgent: false });
  });
  accepted.filter(a => a.assignedCA === CA_MY_NAME && !a.joiningDate).forEach(a => {
    actions.push({ priority: '低', text: `${a.name} — 承諾後入社準備確認`, due: '今週中', urgent: false });
  });
  if (actions.length === 0) {
    actions.push({ priority: '低', text: '本日の対応事項はありません', due: '—', urgent: false });
  }

  return { interviewsFirstToday, interviewsToday, interviewsUpcoming, pendingReply, proposalCandidates, actions };
}


