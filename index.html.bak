  'オープンアップコンストラクション','JAGフィールド','ウィルオブコンストラクション',
  'IDOM','大東建託','大同生命','日本交通','マーキュリー','NECT','GREEN RIBON',
  'アドバンサー','アルティウスリンク（KDDI）','ソフトバンク','ミラエール',
  'キャリアウィンク','マンパワー M-shine','マイナビワークス','テクノ・サービス',
  'UTエイム株式会社','株式会社アウトソーシング',
];
const JOB_TYPE_PRESETS = ['機械','IT','施工管理','事務','営業','接客・販売','製造','IT事務'];
const PROSPECT_RANK_OPTIONS = ['30%','50%','70%','100%'];

function CandidatesPage() {
  const [search, setSearch] = React.useState('');
  const [statusFilter, setStatusFilter] = React.useState('全て');
  const [showEnded, setShowEnded] = React.useState(false);
  const [sortKey, setSortKey] = React.useState('createdAt');
  const [sortDir, setSortDir] = React.useState('desc');

  const loadMyCandidates = () => {
    try {
      const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || 'null');
      if (stored && Array.isArray(stored)) {
        return stored.filter(c => c.assignedCA === CA_MY_NAME);
      }
    } catch {}
    return [];
  };
  const [candidates, setCandidates] = React.useState(loadMyCandidates);

  // フォーカス時に最新データを再読み込み
  React.useEffect(() => {
    const handleFocus = () => setCandidates(loadMyCandidates());
    window.addEventListener('focus', handleFocus);
    return () => window.removeEventListener('focus', handleFocus);
  }, []);

  const loadInterviewPlans = () => {
    try { return JSON.parse(localStorage.getItem('test-crm-interview-plans') || '{}'); } catch { return {}; }
  };
  const [interviewPlans] = React.useState(loadInterviewPlans);

  const getEarliestInterview = (cid) => {
    const plans = interviewPlans[cid] || [];
    const dates = plans.map(p => (p.date || '').substring(0,10)).filter(Boolean).sort();
    return dates[0] || null;
  };

  const handleInlineStatus = (id, newStatus) => {
    const updated = candidates.map(c => c.id === id ? {...c, status: newStatus} : c);
    setCandidates(updated);
    try {
      const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      const merged = stored.map(c => c.id === id ? {...c, status: newStatus} : c);
      localStorage.setItem('test-crm-candidates', JSON.stringify(merged));
    } catch {}
  };

  const handleInlineField = (id, field, value) => {
    const updated = candidates.map(c => c.id === id ? {...c, [field]: value} : c);
    setCandidates(updated);
    try {
      const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      const merged = stored.map(c => c.id === id ? {...c, [field]: value} : c);
      localStorage.setItem('test-crm-candidates', JSON.stringify(merged));
    } catch {}
  };

  const handleEndedToggle = (c) => {
    const newEnded = !c.ended;
    // 終了にするとき endedAt（YYYY-MM）を記録。解除するときはクリア。
    const now = new Date();
    const endedAt = newEnded
      ? `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`
      : null;
    const changes = { ended: newEnded, endedAt };
    const updated = candidates.map(x => x.id === c.id ? {...x, ...changes} : x);
    setCandidates(updated);
    try {
      const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      const merged = stored.map(x => x.id === c.id ? {...x, ...changes} : x);
      localStorage.setItem('test-crm-candidates', JSON.stringify(merged));
    } catch {}
  };

  // 当月（YYYY-MM）
  const currentMonth = (() => {
    const n = new Date();
    return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}`;
  })();

  const statuses = ['全て', ...new Set(candidates.map(c => c.status))];
  const filtered = React.useMemo(() => {
    let data = [...candidates];
    // 終了済み候補者：endedAt が当月の場合のみ表示（翌月以降は非表示）
    data = data.filter(c => {
      if (!c.ended) return true;
      // endedAt がない古いデータは当月扱いで表示（今月中は見える）
      const ea = c.endedAt || currentMonth;
      return ea === currentMonth;
    });
    if (search) data = data.filter(c => c.name.includes(search) || (c.companyName||'').includes(search) || (c.sourceCompany||'').includes(search));
    if (statusFilter !== '全て') data = data.filter(c => c.status === statusFilter);
    data.sort((a, b) => {
      // 終了済みは常に下へ
      if (!!a.ended !== !!b.ended) return a.ended ? 1 : -1;
      if (sortKey === 'status') {
        const ai = CA_STATUS_ORDER.indexOf(a.status);
        const bi = CA_STATUS_ORDER.indexOf(b.status);
        return sortDir === 'asc' ? (ai===-1?999:ai)-(bi===-1?999:bi) : (bi===-1?999:bi)-(ai===-1?999:ai);
      }
      let va = a[sortKey] ?? '', vb = b[sortKey] ?? '';
      if (typeof va === 'number') return sortDir === 'asc' ? va - vb : vb - va;
      return sortDir === 'asc' ? String(va).localeCompare(String(vb)) : String(vb).localeCompare(String(va));
    });
    return data;
  }, [search, statusFilter, sortKey, sortDir, candidates]);

  const handleSort = (key) => {
    if (sortKey === key) setSortDir(d => d === 'asc' ? 'desc' : 'asc');
    else { setSortKey(key); setSortDir('asc'); }
  };
  const sortIcon = (key) => sortKey === key ? (sortDir === 'asc' ? ' ↑' : ' ↓') : '';

  const todayDateStr = new Date().toISOString().slice(0, 10);

  return (
    <div className="card">
      <div className="card-header">
        <div className="card-title">担当求職者一覧 <span className="text-muted" style={{fontWeight:'400'}}>({filtered.length}件)</span></div>
        <div style={{display:'flex', gap:'8px', alignItems:'center'}}>
          <input className="search-input" placeholder="名前・企業名で検索..." value={search} onChange={e=>setSearch(e.target.value)} />
          <select className="filter-select" value={statusFilter} onChange={e=>setStatusFilter(e.target.value)}>
            {statuses.map(s => <option key={s}>{s}</option>)}
          </select>
        </div>
      </div>
      <div className="data-table-wrap" style={{maxHeight:'calc(100vh - 180px)', overflowX:'auto'}}>
        <table className="data-table">
          <thead>
            <tr>
              <th onClick={()=>handleSort('name')} style={{cursor:'pointer'}}>氏名{sortIcon('name')}</th>
              <th style={{minWidth:'130px', cursor:'pointer'}} onClick={()=>handleSort('status')}>ステータス{sortIcon('status')}</th>
              <th onClick={()=>handleSort('firstInterviewDate')} style={{cursor:'pointer',whiteSpace:'nowrap'}}>初回面接{sortIcon('firstInterviewDate')}</th>
              <th onClick={()=>handleSort('age')} style={{cursor:'pointer'}}>年齢{sortIcon('age')}</th>
              <th onClick={()=>handleSort('jobType')} style={{cursor:'pointer'}}>職種{sortIcon('jobType')}</th>
              <th onClick={()=>handleSort('sourceCompany')} style={{cursor:'pointer',whiteSpace:'nowrap'}}>流入企業{sortIcon('sourceCompany')}</th>
              <th style={{whiteSpace:'nowrap'}}>企業提案日程</th>
              <th style={{whiteSpace:'nowrap'}}>推薦</th>
              <th style={{whiteSpace:'nowrap'}}>企業面接</th>
              <th style={{textAlign:'center',width:'44px'}} title="終了チェックで案件を終了にする">終了</th>
            </tr>
          </thead>
          <tbody>
            {filtered.map((c) => {
              const isEnded = !!c.ended;
              const earliestIv = getEarliestInterview(c.id);
              return (
                <tr key={c.id} style={{opacity: isEnded ? 0.45 : 1, background: isEnded ? 'var(--bg-hover)' : ''}}>
                  <td className="name" style={{color: isEnded ? 'var(--text-muted)' : ''}}>{c.name}</td>
                  <td>
                    <select
                      className="filter-select"
                      value={c.status}
                      onChange={e => handleInlineStatus(c.id, e.target.value)}
                      style={{minWidth:'120px', fontSize:'14px'}}
                    >
                      {STATUS_OPTIONS.map(s => <option key={s} value={s}>{s}</option>)}
                    </select>
                  </td>
                  <td style={{fontVariantNumeric:'tabular-nums', whiteSpace:'nowrap', textAlign:'center'}}>
                    {(() => {
                      const d = (c.firstInterviewDate || '').slice(0, 10);
                      const isPast = d && d < todayDateStr;
                      const isInterviewSet = (c.status === '面接設定' || c.status === '初回面接');
                      const warn = isPast && isInterviewSet;
                      return (
                        <span style={{color: warn ? 'var(--danger)' : 'var(--text-secondary)', fontWeight: warn ? '700' : 'normal'}}>
                          {warn && <span title="面接設定のまま日程が過ぎています" style={{marginRight:'3px'}}>⚠️</span>}
                          {fmtMD(c.firstInterviewDate)}
                        </span>
                      );
                    })()}
                  </td>
                  <td style={{textAlign:'center'}}>{c.age}</td>
                  <td><span className="tag">{c.jobType}</span></td>
                  <td style={{color:'var(--text-secondary)', fontSize:'14px', maxWidth:'100px', overflow:'hidden', textOverflow:'ellipsis', whiteSpace:'nowrap'}}>{c.sourceCompany || c.companyName || '—'}</td>
                  <td style={{whiteSpace:'nowrap'}}>
                    <div style={{display:'flex',alignItems:'center',gap:'4px'}}>
                      <input
                        type="date"
                        value={c.proposalDate || ''}
                        onChange={e => handleInlineField(c.id, 'proposalDate', e.target.value)}
                        style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 4px',fontSize:'15px',background:'var(--bg-base)',color:'var(--text-primary)',width:'110px'}}
                      />
                      {c.proposalDate && <span style={{fontSize:'15px',color:'var(--accent)',fontWeight:'600'}}>{fmtMD(c.proposalDate)}</span>}
                    </div>
                  </td>
                  <td style={{whiteSpace:'nowrap'}}>
                    <div style={{display:'flex',alignItems:'center',gap:'4px'}}>
                      <input
                        type="date"
                        value={c.recommendationDate || c.recommendedDate || ''}
                        onChange={e => handleInlineField(c.id, 'recommendationDate', e.target.value)}
                        style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 4px',fontSize:'15px',background:'var(--bg-base)',color:'var(--text-primary)',width:'110px'}}
                      />
                      {(c.recommendationDate || c.recommendedDate) && <span style={{fontSize:'15px',color:'var(--accent)',fontWeight:'600'}}>{fmtMD(c.recommendationDate || c.recommendedDate)}</span>}
                    </div>
                  </td>
                  <td style={{textAlign:'center', fontVariantNumeric:'tabular-nums', color: earliestIv ? 'var(--accent)' : 'var(--text-muted)', fontWeight: earliestIv ? '600' : '400', whiteSpace:'nowrap'}}>
                    {earliestIv ? fmtMD(earliestIv) : '—'}
                  </td>
                  <td style={{textAlign:'center'}}>
                    <input type="checkbox" checked={isEnded} onChange={()=>handleEndedToggle(c)}
                      title={isEnded ? '終了解除' : '終了にする'}
                      style={{width:'15px',height:'15px',cursor:'pointer',accentColor:'var(--danger)'}}
                    />
                  </td>
                </tr>
              );
            })}
            {filtered.length === 0 && (
              <tr><td colSpan={10} style={{textAlign:'center',padding:'32px',color:'var(--text-muted)'}}>該当する求職者がいません</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  );
}

function ProgressPage({ period }) {
  const [metrics, setMetrics] = React.useState(() => _loadMyMetrics(period));
  React.useEffect(() => {
    setMetrics(_loadMyMetrics(period)); // 月変更時に即時更新
    const reload = () => setMetrics(_loadMyMetrics(period));
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, [period]);
  const MY_KPI = metrics.kpi;
  const STAGE_PROGRESS = metrics.stageProgress;
  const RATE_KPIS = metrics.rateKpis;
  const MY_REVENUE = metrics.revenue || { current: 0, target: 3000000, requiredByToday: 0 };
  const now = new Date();
  const [selY, selM] = period ? period.split('/').map(Number) : [now.getFullYear(), now.getMonth()+1];
  const daysInMonth = new Date(selY, selM, 0).getDate();
  const isCurrentMonth = selY === now.getFullYear() && selM === (now.getMonth()+1);
  const dayOfMonth = isCurrentMonth ? now.getDate() : daysInMonth;
  return (
    <div style={{display:'flex',flexDirection:'column',gap:'14px'}}>
      <div style={{
        background:'var(--accent-subtle)', border:'1px solid var(--accent-light)',
        borderRadius:'var(--radius)', padding:'10px 16px', fontSize:'14px', color:'var(--accent)',
        display:'flex', alignItems:'center', gap:'8px'
      }}>
        <strong>{selM}月{isCurrentMonth ? dayOfMonth+'日時点' : '（確定値）'}</strong>
        <span style={{color:'var(--text-secondary)'}}>— 月間 {daysInMonth} 日中 {dayOfMonth} 日経過（{Math.round(dayOfMonth/daysInMonth*100)}%）</span>
        <span style={{color:'var(--text-muted)', fontSize:'15px', marginLeft:'4px'}}>{isCurrentMonth ? '「本日目標」= 月間目標 × 経過日数÷月間日数' : '「月末目標」= 月間目標（最終月実績）'}</span>
      </div>

      {/* 1段目: KPI進捗（ドーナツ9種） */}
      <div className="card">
        <div className="card-header">
          <div className="card-title">KPI進捗</div>
          <div className="card-subtitle" style={{marginLeft:'auto'}}>面接設定 → 承諾 の各ステージ</div>
        </div>
        <div className="card-body" style={{paddingTop:'8px'}}>
          <div style={{display:'grid', gridTemplateColumns:'repeat(9,1fr)', gap:'10px'}}>
            <DonutKPICard label="面接設定"    value={MY_KPI.interviewSet.value}      target={MY_KPI.interviewSet.target}      color="var(--chart-2)" monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="飛び+辞退"   value={MY_KPI.flyDropout.value}        target={MY_KPI.flyDropout.target}        color="var(--danger)"  monthRatio={dayOfMonth/daysInMonth} lowerIsBetter={true} />
            <DonutKPICard label="初回面接"    value={MY_KPI.initialInterview.value}  target={MY_KPI.initialInterview.target}  color="var(--chart-4)" monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="ブリッジ成功" value={MY_KPI.bridgeSuccess.value}    target={MY_KPI.bridgeSuccess.target}     color="var(--chart-3)" monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="企業提案"    value={MY_KPI.proposal.value}          target={MY_KPI.proposal.target}          color="var(--chart-1)" monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="推薦"        value={MY_KPI.recommendation.value}    target={MY_KPI.recommendation.target}    color="#8b5cf6"        monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="企業面接"    value={MY_KPI.companyInterview.value}  target={MY_KPI.companyInterview.target}  color="var(--accent)"  monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="内定"        value={MY_KPI.offer.value}             target={MY_KPI.offer.target}             color="var(--chart-3)" monthRatio={dayOfMonth/daysInMonth} />
            <DonutKPICard label="承諾"        value={MY_KPI.acceptance.value}        target={MY_KPI.acceptance.target}        color="var(--success)" monthRatio={dayOfMonth/daysInMonth} />
          </div>
        </div>
      </div>

      {/* 2段目: 率KPI */}
      <div className="card">
        <div className="card-header">
          <div className="card-title">率KPI</div>
          <div className="card-subtitle" style={{marginLeft:'auto'}}>転換率・飛び率 一覧</div>
        </div>
        <div className="card-body">
          <div style={{display:'grid', gridTemplateColumns:'repeat(7,1fr)', gap:'10px'}}>
            {RATE_KPIS.map((r, i) => <RateKPICard key={i} {...r} />)}
          </div>
        </div>
      </div>

      {/* ステージ別進捗テーブル */}
      <div className="card">
        <div className="card-header">
          <div className="card-title">ステージ別進捗</div>
          <div className="card-subtitle" style={{marginLeft:'auto'}}>{isCurrentMonth ? '青: 本日目標 / 全体達成率も表示' : '月次確定値'}</div>
        </div>
        <div className="card-body" style={{padding:'8px 0', overflowX:'auto'}}>
          <ProgressTableSection data={STAGE_PROGRESS} showTodayTarget={true} isCurrentMonth={isCurrentMonth} />
        </div>
      </div>
    </div>
  );
}

function RevenuePage({ period }) {
  const loadRevCandidates = () => {
    try {
      const s = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      return Array.isArray(s) ? s.filter(c => c.assignedCA === CA_MY_NAME) : [];
    } catch { return []; }
  };
  const [revCands, setRevCands] = React.useState(loadRevCandidates);
  const [revMetrics, setRevMetrics] = React.useState(() => _loadMyMetrics(period));
  React.useEffect(() => {
    setRevCands(loadRevCandidates()); setRevMetrics(_loadMyMetrics(period)); // 月変更時に即時更新
    const reload = () => { setRevCands(loadRevCandidates()); setRevMetrics(_loadMyMetrics(period)); };
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, [period]);
  const MY_REVENUE = revMetrics.revenue || { current: 0, target: 3000000, requiredByToday: 0 };
  const caStatus = c => c.caStatus || c.status || '';

  // 見込みランクは「推薦」ステージ以降のみ対象
  // ランクは企業面接管理で CA が手動設定（meta.rank）。未設定時はステージ別デフォルト
  const loadRevMeta = () => { try { return JSON.parse(localStorage.getItem('test-crm-candidate-meta') || '{}'); } catch { return {}; } };
  const loadRevPlans = () => { try { return JSON.parse(localStorage.getItem('test-crm-interview-plans') || '{}'); } catch { return {}; } };
  const [revMeta] = React.useState(loadRevMeta);
  const [revPlans] = React.useState(loadRevPlans);

  // 選択月キー（"2026/05" → "2026-05"）
  const periodKey = period ? period.replace('/', '-') : (() => {
    const n = new Date();
    return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}`;
  })();

  const FORECAST_ST = ['推薦','面接対策１','面接対策２','企業面接','企業面接1','企業面接2','内定','承諾'];
  // ランク別一覧：選択月に面接日がある人のみ表示
  const forecastCands = revCands.filter(c => {
    if (!FORECAST_ST.includes(caStatus(c))) return false;
    // その月に interview plans の date がある
    const cpList = revPlans[c.id] || [];
    return cpList.some(cp => (cp.date || '').startsWith(periodKey));
  });
  const getEffectiveRank = (c) => {
    const mr = (revMeta[c.id] || {}).rank;
    if (mr) return mr;
    const cs = caStatus(c);
    if (['承諾','内定'].includes(cs)) return '100%';
    if (['企業面接','企業面接1','企業面接2','面接対策１','面接対策２'].includes(cs)) return '70%';
    return '50%'; // 推薦 デフォルト
  };
  const rank100 = forecastCands.filter(c => getEffectiveRank(c) === '100%');
  const rank70  = forecastCands.filter(c => getEffectiveRank(c) === '70%');
  const rank50  = forecastCands.filter(c => getEffectiveRank(c) === '50%');
  const rank30  = forecastCands.filter(c => getEffectiveRank(c) === '30%');
  const rankData = [
    { rank: '100%', items: rank100, weight: 1.0 },
    { rank: '70%',  items: rank70,  weight: 0.7 },
    { rank: '50%',  items: rank50,  weight: 0.5 },
    { rank: '30%',  items: rank30,  weight: 0.3 },
  ];
  const totalWeighted = rankData.reduce((sum, r) => sum + r.items.reduce((s, c) => s + c.expectedRevenue * r.weight, 0), 0);
  return (
    <div style={{display:'flex',flexDirection:'column',gap:'14px'}}>
      <div className="kpi-grid" style={{gridTemplateColumns:'repeat(4,1fr)'}}>
        <div className="kpi-card" style={{'--kpi-color':'var(--chart-3)'}}>
          <div className="kpi-label">承諾数</div>
          <div className="kpi-value">{rank100.length}</div>
          <div className="kpi-target">内定含む確定分</div>
        </div>
        <div className="kpi-card" style={{'--kpi-color':'var(--chart-1)'}}>
          <div className="kpi-label">受注金額</div>
          <div className="kpi-value" style={{fontSize:'20px'}}>{fmtYen(MY_REVENUE.current)}</div>
          <div className="kpi-target">目標: {fmtYen(MY_REVENUE.target)}</div>
        </div>
        <div className="kpi-card" style={{'--kpi-color':'var(--chart-4)'}}>
          <div className="kpi-label">見込み売上</div>
          <div className="kpi-value" style={{fontSize:'20px'}}>{fmtYen(forecastCands.reduce((s,c)=>s+c.expectedRevenue,0))}</div>
          <div className="kpi-target">全見込合計</div>
        </div>
        <div className="kpi-card" style={{'--kpi-color':'var(--chart-2)'}}>
          <div className="kpi-label">加重見込み</div>
          <div className="kpi-value" style={{fontSize:'20px'}}>{fmtYen(Math.round(totalWeighted))}</div>
          <div className="kpi-target">確率加重平均</div>
        </div>
      </div>
      <div className="grid-2">
        <div className="card">
          <div className="card-header"><div className="card-title">受注進捗ドーナツ</div></div>
          <div className="card-body" style={{display:'flex',justifyContent:'center'}}>
            <DonutChart target={MY_REVENUE.target} requiredByToday={MY_REVENUE.requiredByToday} current={MY_REVENUE.current} size={170} />
          </div>
        </div>
        <div className="card">
          <div className="card-header"><div className="card-title">ランク別・求職者一覧</div></div>
          <div className="card-body" style={{padding:'0'}}>
            {rankData.map((r, i) => {
              const rankColor = i===0?'var(--success)':i===1?'var(--accent)':i===2?'var(--chart-4)':'var(--text-muted)';
              return r.items.length > 0 ? (
                <div key={i} style={{borderBottom:'1px solid var(--border-light)', padding:'8px 16px'}}>
                  <div style={{display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:'6px'}}>
                    <span style={{fontWeight:'700', fontSize:'14px', color:rankColor}}>{r.rank} 確率</span>
                    <span style={{fontSize:'15px', color:'var(--text-muted)'}}>計: {fmtYen(r.items.reduce((s,c)=>s+c.expectedRevenue,0))} → 加重: {fmtYen(Math.round(r.items.reduce((s,c)=>s+c.expectedRevenue*r.weight,0)))}</span>
                  </div>
                  {r.items.map((c, j) => (
                    <div key={j} style={{display:'flex', justifyContent:'space-between', alignItems:'center', padding:'3px 0', fontSize:'14px'}}>
                      <span style={{fontWeight:'500'}}>{c.name}</span>
                      <div style={{display:'flex', gap:'8px', alignItems:'center'}}>
                        <StatusBadge status={caStatus(c)} />
                        <span style={{fontWeight:'700', color:'var(--success)', minWidth:'80px', textAlign:'right'}}>{fmtYen(c.expectedRevenue)}</span>
                      </div>
                    </div>
                  ))}
                </div>
              ) : null;
            })}
          </div>
        </div>
      </div>
    </div>
  );
}

function ActionsPage() {
  const [actions, setActions] = React.useState(() => _loadSummaryData().actions);
  React.useEffect(() => {
    const reload = () => setActions(_loadSummaryData().actions);
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, []);
  return (
    <div className="card">
      <div className="card-header">
        <div className="card-title">対応事項一覧</div>
        <span className="badge-count" style={{background:'var(--danger)'}}>{actions.filter(a=>a.urgent).length} 緊急</span>
      </div>
      <div className="card-body">
        {actions.length === 0
          ? <div className="empty-state">対応事項はありません</div>
          : actions.map((a, i) => (
          <div key={i} className="action-item" style={{padding:'10px 0'}}>
            <span className="action-priority" style={{
              background: a.priority==='高'?'var(--danger-bg)':a.priority==='中'?'var(--warning-bg)':'var(--info-bg)',
              color: a.priority==='高'?'var(--danger)':a.priority==='中'?'var(--warning)':'var(--info)',
            }}>{a.priority}</span>
            <div style={{flex:1}}>
              <div className="action-text">{a.text}</div>
              <div className="action-due">期限: {a.due}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

function InterviewsPage() {
  const loadCandidates = () => {
    try {
      const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      return Array.isArray(stored) ? stored.filter(c => c.assignedCA === CA_MY_NAME) : [];
    } catch { return []; }
  };
  const loadPlans = () => { try { return JSON.parse(localStorage.getItem('test-crm-interview-plans') || '{}'); } catch { return {}; } };
  const loadMeta = () => { try { return JSON.parse(localStorage.getItem('test-crm-candidate-meta') || '{}'); } catch { return {}; } };

  const [candidates, setCandidates] = React.useState(loadCandidates);
  React.useEffect(() => {
    const reload = () => setCandidates(loadCandidates());
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, []);
  const [plans, setPlans] = React.useState(loadPlans);
  const [meta, setMeta] = React.useState(loadMeta);

  const pipelineCandidates = React.useMemo(() =>
    candidates.filter(c => {
      const cs = c.caStatus || c.status || '';
      return ['推薦','面接対策１','面接対策２','企業面接','企業面接1','企業面接2','選考中','内定','承諾'].includes(cs);
    })
  , [candidates]);

  const savePlans = (newPlans) => {
    setPlans(newPlans);
    try { localStorage.setItem('test-crm-interview-plans', JSON.stringify(newPlans)); } catch {}
  };
  const saveMeta = (newMeta) => {
    setMeta(newMeta);
    try { localStorage.setItem('test-crm-candidate-meta', JSON.stringify(newMeta)); } catch {}
  };

  const addCompany = (cid) => {
    savePlans({ ...plans, [cid]: [...(plans[cid] || []), { company: '', date: '', selectionStatus: '書類選考中', offerDeadline: '', pendingConfirm: false, alertDays: 3 }] });
  };
  const updateCompany = (cid, idx, field, value) => {
    const arr = [...(plans[cid] || [])];
    arr[idx] = { ...arr[idx], [field]: value };
    savePlans({ ...plans, [cid]: arr });
    if (field === 'selectionStatus') {
      const companyName = arr[idx].company || '';
      if (value === '内定承諾') {
        // 内定承諾時に crm-accepted へ自動登録
        try {
          const acc = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
          const cand = candidates.find(c => c.id === cid);
          if (cand) {
            const alreadyExists = acc.some(a => a.id === cid && a.companyName === companyName);
            if (!alreadyExists) {
              const _today = new Date().toISOString().slice(0,10);
              acc.push({
                ...cand,
                companyName,
                acceptanceDate: _today,
                acceptedAt: _today,
                joiningDate: '',
                contractAmount: '',
                memo: cand.memo || '',
              });
              localStorage.setItem('test-crm-accepted', JSON.stringify(acc));
            }
          }
        } catch {}
      } else {
        // 内定承諾以外に戻した場合は crm-accepted から削除（誤登録の取り消し）
        try {
          const acc = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
          const prevStatus = (plans[cid]?.[idx]?.selectionStatus) || '';
          if (prevStatus === '内定承諾') {
            const cleaned = acc.filter(a => !(a.id === cid && a.companyName === companyName));
            localStorage.setItem('test-crm-accepted', JSON.stringify(cleaned));
          }
        } catch {}
      }
    }
  };
  const removeCompany = (cid, idx) => {
    const arr = [...(plans[cid] || [])];
    arr.splice(idx, 1);
    savePlans({ ...plans, [cid]: arr });
  };
  const updateMeta = (cid, field, value) => {
    saveMeta({ ...meta, [cid]: { ...(meta[cid] || {}), [field]: value } });
  };

  const getRowStyle = (status) => {
    const grayed = ['選考辞退','書類お見送り','面接お見送り'].includes(status);
    if (grayed) return { bg: '#9ca3af', color: '#ffffff', opacity: 1 };
    if (status === 'オファー面談' || status === '内定') return { bg: '#fff3e0', color: '#d97706', opacity: 1 };
    if (status === '内定承諾' || status === '入社確定') return { bg: '#f97316', color: '#ffffff', opacity: 1 };
    return { bg: 'var(--bg-card)', color: 'var(--text-primary)', opacity: 1 };
  };

  return (
    <div style={{display:'flex', flexDirection:'column', gap:'14px'}}>
      <div className="card">
        <div className="card-header">
          <div className="card-title">📋 推薦済み・選考ステータス</div>
          <span className="badge-count">{pipelineCandidates.length}</span>
        </div>
        <div className="card-body" style={{display:'flex',flexDirection:'column',gap:'16px',padding:'12px'}}>
          {pipelineCandidates.length === 0 && (
            <div style={{color:'var(--text-muted)',fontSize:'15px',padding:'24px 0',textAlign:'center'}}>
              推薦済みの求職者がいません
            </div>
          )}
          {pipelineCandidates.map(c => {
            const m = meta[c.id] || {};
            const companyList = plans[c.id] || [];
            return (
              <div key={c.id} style={{border:'1px solid var(--border)',borderRadius:'var(--radius)',overflow:'hidden',boxShadow:'var(--shadow)'}}>
                {/* 候補者ヘッダー */}
                <div style={{background:'var(--accent-subtle)',borderBottom:'1px solid var(--border)',padding:'10px 14px',display:'flex',flexWrap:'wrap',gap:'10px',alignItems:'center'}}>
                  <span style={{fontWeight:'700',fontSize:'14px',color:'var(--text-primary)',minWidth:'90px'}}>{c.name}</span>
                  <StatusBadge status={c.status} />
                  <label style={{display:'flex',alignItems:'center',gap:'4px',fontSize:'14px',color:'var(--text-secondary)'}}>
                    見込み:
                    <select value={m.rank || ''} onChange={e=>updateMeta(c.id,'rank',e.target.value)}
                      style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 6px',fontSize:'14px',background:'var(--bg-card)',color: m.rank==='100%'?'var(--success)':m.rank==='70%'?'var(--accent)':'var(--text-primary)',fontWeight:'600'}}>
                      <option value="">-</option>
                      {PROSPECT_RANK_OPTIONS.map(r=><option key={r} value={r}>{r}</option>)}
                    </select>
                  </label>
                  <label style={{display:'flex',alignItems:'center',gap:'4px',fontSize:'14px',color:'var(--text-secondary)'}}>
                    他社選考:
                    <select value={m.hasOtherSelection || ''} onChange={e=>updateMeta(c.id,'hasOtherSelection',e.target.value)}
                      style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 6px',fontSize:'14px',background:'var(--bg-card)'}}>
                      <option value="">-</option>
                      <option value="あり">あり</option>
                      <option value="なし">なし</option>
                    </select>
                  </label>
                  <label style={{display:'flex',alignItems:'center',gap:'4px',fontSize:'14px',color:'var(--text-secondary)'}}>
                    他エージェント:
                    <select value={m.hasAgent || ''} onChange={e=>updateMeta(c.id,'hasAgent',e.target.value)}
                      style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 6px',fontSize:'14px',background:'var(--bg-card)'}}>
                      <option value="">-</option>
                      <option value="あり">あり</option>
                      <option value="なし">なし</option>
                    </select>
                  </label>
                  <label style={{display:'flex',alignItems:'center',gap:'4px',fontSize:'14px',color:'var(--text-secondary)'}}>
                    希望入社月:
                    <input type="month" value={m.desiredJoinMonth || ''} onChange={e=>updateMeta(c.id,'desiredJoinMonth',e.target.value)}
                      style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 6px',fontSize:'14px',background:'var(--bg-card)',color:'var(--text-primary)'}} />
                  </label>
                  <button onClick={()=>addCompany(c.id)}
                    style={{marginLeft:'auto',background:'var(--accent)',color:'#fff',border:'none',borderRadius:'4px',padding:'5px 14px',fontSize:'14px',cursor:'pointer',fontWeight:'600',whiteSpace:'nowrap'}}>
                    ＋ 企業追加
                  </button>
                </div>
                {/* 企業リスト */}
                {companyList.length === 0 ? (
                  <div style={{padding:'10px 14px',fontSize:'14px',color:'var(--text-muted)'}}>「＋ 企業追加」で企業を登録してください</div>
                ) : (
                  <table style={{width:'100%',borderCollapse:'collapse',fontSize:'14px'}}>
                    <thead>
                      <tr style={{background:'var(--bg-base)',borderBottom:'1px solid var(--border)'}}>
                        <th style={{padding:'6px 10px',textAlign:'center',fontWeight:'600',color:'var(--text-secondary)',width:'36px'}}>#</th>
                        <th style={{padding:'6px 10px',textAlign:'left',fontWeight:'600',color:'var(--text-secondary)'}}>企業名</th>
                        <th style={{padding:'6px 10px',textAlign:'left',fontWeight:'600',color:'var(--text-secondary)',width:'110px',whiteSpace:'nowrap'}}>職種</th>
                        <th style={{padding:'6px 10px',textAlign:'left',fontWeight:'600',color:'var(--text-secondary)',width:'170px',whiteSpace:'nowrap'}}>面接日程</th>
                        <th style={{padding:'6px 10px',textAlign:'center',fontWeight:'600',color:'var(--text-secondary)',width:'70px',whiteSpace:'nowrap'}}>確定返信</th>
                        <th style={{padding:'6px 10px',textAlign:'left',fontWeight:'600',color:'var(--text-secondary)',width:'160px',whiteSpace:'nowrap'}}>選考ステータス</th>
                        <th style={{padding:'6px 10px',textAlign:'left',fontWeight:'600',color:'var(--text-secondary)',width:'120px',whiteSpace:'nowrap'}}>承諾期限</th>
                        <th style={{padding:'6px 10px',width:'48px'}}></th>
                      </tr>
                    </thead>
                    <tbody>
                      {companyList.map((cp, idx) => {
                        const rs = getRowStyle(cp.selectionStatus);
                        const isCustomCompany = cp.company && !COMPANY_PRESETS.includes(cp.company);
                        const isCustomJobType = cp.jobType && !JOB_TYPE_PRESETS.includes(cp.jobType);
                        return (
                          <tr key={idx} style={{background:rs.bg,borderBottom:'1px solid var(--border-light)',opacity:rs.opacity}}>
                            <td style={{padding:'6px 10px',color:'var(--text-muted)',textAlign:'center',fontWeight:'600'}}>{idx+1}</td>
                            <td style={{padding:'6px 10px'}}>
                              <select value={isCustomCompany ? '自己記入' : (cp.company || '')}
                                onChange={e => {
                                  if (e.target.value === '自己記入') {
                                    updateCompany(c.id, idx, 'company', '');
                                  } else {
                                    updateCompany(c.id, idx, 'company', e.target.value);
                                  }
                                }}
                                style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'3px 6px',fontSize:'14px',background:rs.bg,color:rs.color,width:'100%',marginBottom: isCustomCompany ? '4px' : '0'}}>
                                <option value="">-- 選択 --</option>
                                {COMPANY_PRESETS.map(co=><option key={co} value={co}>{co}</option>)}
                                <option value="自己記入">自己記入</option>
                              </select>
                              {isCustomCompany && (
                                <input type="text" value={cp.company || ''} placeholder="企業名を入力..."
                                  onChange={e=>updateCompany(c.id,idx,'company',e.target.value)}
                                  style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'3px 8px',fontSize:'14px',background:'transparent',color:rs.color,width:'100%'}} />
                              )}
                            </td>
                            <td style={{padding:'6px 10px'}}>
                              <select value={isCustomJobType ? '自己記入' : (cp.jobType || '')}
                                onChange={e => {
                                  if (e.target.value === '自己記入') {
                                    updateCompany(c.id, idx, 'jobType', '');
                                  } else {
                                    updateCompany(c.id, idx, 'jobType', e.target.value);
                                  }
                                }}
                                style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'3px 6px',fontSize:'14px',background:rs.bg,color:rs.color,width:'100%',marginBottom: isCustomJobType ? '4px' : '0'}}>
                                <option value="">-- 選択 --</option>
                                {JOB_TYPE_PRESETS.map(jt=><option key={jt} value={jt}>{jt}</option>)}
                                <option value="自己記入">自己記入</option>
                              </select>
                              {isCustomJobType && (
                                <input type="text" value={cp.jobType || ''} placeholder="職種を入力..."
                                  onChange={e=>updateCompany(c.id,idx,'jobType',e.target.value)}
                                  style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'3px 8px',fontSize:'14px',background:'transparent',color:rs.color,width:'100%'}} />
                              )}
                            </td>
                            <td style={{padding:'6px 10px'}}>
                              <div style={{display:'flex',gap:'3px',alignItems:'center'}}>
                                <input type="date" value={(cp.date||'').slice(0,10)}
                                  onChange={e=>updateCompany(c.id,idx,'date',e.target.value+'T'+((cp.date||'').slice(11,16)||'00:00'))}
                                  style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 4px',fontSize:'14px',background:'transparent',color:rs.color,width:'108px'}}/>
                                <select value={(cp.date||'').slice(11,16)||''}
                                  onChange={e=>updateCompany(c.id,idx,'date',((cp.date||'').slice(0,10)||new Date().toISOString().slice(0,10))+'T'+e.target.value)}
                                  style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 4px',fontSize:'14px',background:'transparent',color:rs.color,width:'62px'}}>
                                  <option value="">--:--</option>
                                  {Array.from({length:28},(_,i)=>{const h=String(Math.floor(i/2)+8).padStart(2,'0');const mn=i%2===0?'00':'30';return <option key={i} value={`${h}:${mn}`}>{`${h}:${mn}`}</option>;})}
                                </select>
                              </div>
                            </td>
                            <td style={{padding:'6px 10px',textAlign:'center'}}>
                              <label style={{display:'flex',flexDirection:'column',alignItems:'center',gap:'2px',cursor:'pointer'}}>
                                <input type="checkbox" checked={!!cp.pendingConfirm}
                                  onChange={e=>updateCompany(c.id,idx,'pendingConfirm',e.target.checked)}
                                  style={{width:'16px',height:'16px',cursor:'pointer',accentColor:'var(--success)'}} />
                                {cp.pendingConfirm && <span style={{fontSize:'10px',color:'var(--success)',fontWeight:'700',whiteSpace:'nowrap'}}>確定済み</span>}
                              </label>
                            </td>
                            <td style={{padding:'6px 10px'}}>
                              <select value={cp.selectionStatus || '書類選考中'}
                                onChange={e=>updateCompany(c.id,idx,'selectionStatus',e.target.value)}
                                style={{border:'1px solid var(--border)',borderRadius:'4px',padding:'3px 6px',fontSize:'14px',
                                  background:rs.bg,color:rs.color,fontWeight:['選考辞退','書類お見送り','面接お見送り'].includes(cp.selectionStatus)?'400':'600',width:'100%'}}>
                                {SELECTION_STATUS_OPTIONS.map(s=><option key={s} value={s}>{s}</option>)}
                              </select>
                            </td>
                            <td style={{padding:'6px 10px'}}>
                              {cp.selectionStatus === '内定' ? (() => {
                                const _now2 = new Date();
                                const _todayStr2 = _now2.toISOString().slice(0,10);
                                const _alertDays = cp.alertDays !== undefined ? Number(cp.alertDays) : 3;
                                const _alertDate = new Date(_now2); _alertDate.setDate(_alertDate.getDate() + _alertDays);
                                const _alertDateStr = _alertDate.toISOString().slice(0,10);
                                const _isPast = cp.offerDeadline && cp.offerDeadline < _todayStr2;
                                const _isAlert = cp.offerDeadline && !_isPast && cp.offerDeadline <= _alertDateStr;
                                const _daysLeft = cp.offerDeadline ? Math.ceil((new Date(cp.offerDeadline) - new Date(_todayStr2)) / 86400000) : null;
                                return (
                                  <div>
                                    <input type="date" value={cp.offerDeadline || ''}
                                      onChange={e=>updateCompany(c.id,idx,'offerDeadline',e.target.value)}
                                      style={{border:`2px solid ${_isAlert?'#d97706':_isPast?'#ef4444':'var(--border)'}`,borderRadius:'6px',
                                        padding:'4px 8px',fontSize:'14px',fontWeight:'600',
                                        background:_isAlert?'#fff3e0':_isPast?'#fee2e2':'transparent',
                                        color:_isAlert?'#d97706':_isPast?'#ef4444':rs.color,width:'120px'}} />
                                    {_isAlert && _daysLeft !== null && (
                                      <div style={{marginTop:'4px',padding:'3px 8px',borderRadius:'6px',background:'#fff3e0',border:'1px solid #d97706',display:'inline-block'}}>
                                        <span style={{fontSize:'13px',color:'#d97706',fontWeight:'700'}}>
                                          ⚠ {_daysLeft === 0 ? '本日期限' : _daysLeft === 1 ? '明日まで' : `あと${_daysLeft}日`}
                                        </span>
                                      </div>
                                    )}
                                    {_isPast && (
                                      <div style={{marginTop:'4px',padding:'3px 8px',borderRadius:'6px',background:'#fee2e2',border:'1px solid #ef4444',display:'inline-block'}}>
                                        <span style={{fontSize:'13px',color:'#ef4444',fontWeight:'700'}}>⚠ 期限切れ</span>
                                      </div>
                                    )}
                                  </div>
                                );
                              })() : <span style={{color:'var(--text-muted)',fontSize:'13px'}}>—</span>}
                            </td>
                            <td style={{padding:'6px 10px',textAlign:'center'}}>
                              <button onClick={()=>removeCompany(c.id,idx)}
                                style={{background:'none',border:'1px solid var(--border)',borderRadius:'4px',padding:'2px 6px',fontSize:'14px',color:'var(--danger)',cursor:'pointer'}}>
                                削除
                              </button>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}

const ACCEPT_MILESTONES = [
  { id: 'accepted',   label: '承諾',           icon: '✓' },
  { id: 'procedures', label: '書類手続き完了',   icon: '📋' },
  { id: 'joinDate',   label: '入社確定',       icon: '📅' },
  { id: 'oneMonth',   label: '1ヶ月フォロー済',  icon: '🎯' },
];

function PostAcceptPage({ period }) {
  const [activeTab, setActiveTab] = useState('monthly'); // 'management' | 'monthly'

  // 選択月（period="2026/04"）を基準に直近6ヶ月を生成
  const getThreeMonths = () => {
    const result = [];
    let baseY, baseM;
    if (period) {
      [baseY, baseM] = period.split('/').map(Number);
    } else {
      const now = new Date();
      baseY = now.getFullYear(); baseM = now.getMonth() + 1;
    }
    for (let i = 5; i >= 0; i--) {
      const d = new Date(baseY, baseM - 1 - i, 1);
      result.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`);
    }
    return result;
  };
  const threeMonths = getThreeMonths();

  const loadAccepted = () => {
    try {
      const acc = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      return acc
        .filter(a => a.assignedCA === CA_MY_NAME)
        .filter(a => {
          // acceptedAt または acceptanceDate で判定（どちらもなければ表示する）
          const dateStr = a.acceptedAt || a.acceptanceDate || '';
          if (!dateStr) return true;
          const ym = dateStr.slice(0, 7); // "YYYY-MM"
          return threeMonths.includes(ym);
        });
    } catch { return []; }
  };
  const loadMilestones = () => {
    try { return JSON.parse(localStorage.getItem('test-crm-post-accept-milestones') || '{}'); } catch { return {}; }
  };

  const [accepted, setAccepted] = useState(loadAccepted);
  const [milestoneState, setMilestoneState] = useState(loadMilestones);

  React.useEffect(() => {
    setAccepted(loadAccepted()); // 月変更時に即時更新
    const reload = () => { setAccepted(loadAccepted()); setMilestoneState(loadMilestones()); };
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, [period]);

  const getMilestones = (id) => ({
    accepted: true, procedures: false, joinDate: false, oneMonth: false,
    ...(milestoneState[id] || {}),
  });

  // period変更時のみ並び順を確定（ボタン操作で順番が変わらないようにする）
  const [sortedIds, setSortedIds] = React.useState([]);
  React.useEffect(() => {
    const ms = (() => { try { return JSON.parse(localStorage.getItem('test-crm-post-accept-milestones') || '{}'); } catch { return {}; } })();
    const getScore = id => {
      const m = { accepted: true, procedures: false, joinDate: false, oneMonth: false, ...(ms[id] || {}) };
      if (!m.procedures) return 0;
      if (!m.joinDate)   return 1;
      if (!m.oneMonth)   return 2;
      return 3;
    };
    const sorted = [...accepted].sort((a, b) => getScore(a.id) - getScore(b.id));
    setSortedIds(sorted.map(a => a.id));
  }, [accepted]);

  const recordsMap = Object.fromEntries(accepted.map(a => [a.id, {
    id: a.id, name: a.name,
    company: a.companyName || a.company || '—',
    acceptDate: (a.acceptedAt || a.acceptanceDate || '').slice(0,10) || '',
    joinDate: a.joiningDate || '未定',
    revenue: Number(a.contractAmount) || 0,
    milestones: getMilestones(a.id),
  }]));
  // 確定済み並び順で表示（ボタン操作では順番変わらず）
  const records = sortedIds.length > 0
    ? sortedIds.map(id => recordsMap[id]).filter(Boolean)
    : accepted.map(a => recordsMap[a.id]);

  const toggleMilestone = (personId, milestoneId) => {
    if (milestoneId === 'accepted') return;
    setMilestoneState(prev => {
      const cur = { accepted: true, procedures: false, joinDate: false, oneMonth: false, ...(prev[personId] || {}) };
      const next = { ...prev, [personId]: { ...cur, [milestoneId]: !cur[milestoneId] } };
      try { localStorage.setItem('test-crm-post-accept-milestones', JSON.stringify(next)); } catch {}
      return next;
    });
  };

  const updateRevenue = (id, value) => {
    try {
      const all = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const updated = all.map(a => a.id === id ? { ...a, contractAmount: Number(value) || 0 } : a);
      localStorage.setItem('test-crm-accepted', JSON.stringify(updated));
      setAccepted(updated.filter(a => a.assignedCA === CA_MY_NAME));
    } catch {}
  };

  const updateJoinDate = (id, value) => {
    try {
      const all = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const updated = all.map(a => a.id === id ? { ...a, joiningDate: value } : a);
      localStorage.setItem('test-crm-accepted', JSON.stringify(updated));
      setAccepted(updated.filter(a => a.assignedCA === CA_MY_NAME));
    } catch {}
  };

  // 承諾日を編集 → acceptedAt と acceptanceDate 両方を更新（月次カウントに反映）
  const updateAcceptDate = (id, value) => {
    try {
      const all = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const updated = all.map(a => a.id === id ? { ...a, acceptedAt: value, acceptanceDate: value } : a);
      localStorage.setItem('test-crm-accepted', JSON.stringify(updated));
      setAccepted(updated.filter(a => a.assignedCA === CA_MY_NAME).filter(a => {
        const dateStr = a.acceptedAt || a.acceptanceDate || '';
        if (!dateStr) return true;
        return threeMonths.includes(dateStr.slice(0,7));
      }));
    } catch {}
  };

  const deleteAccepted = (id, name) => {
    if (!window.confirm(`「${name}」を承諾後管理から削除しますか？\nこの操作は取り消せません。`)) return;
    try {
      const all = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const updated = all.filter(a => a.id !== id);
      localStorage.setItem('test-crm-accepted', JSON.stringify(updated));
      setAccepted(updated.filter(a => a.assignedCA === CA_MY_NAME));
    } catch {}
  };

  const getProgress = (id) => {
    const m = getMilestones(id);
    const done = Object.values(m).filter(Boolean).length;
    return Math.round((done / ACCEPT_MILESTONES.length) * 100);
  };

  // 表示期間ラベル（例: "2025年12月〜2026年5月"）
  const periodLabel = (() => {
    const first = threeMonths[0];
    const last = threeMonths[threeMonths.length - 1];
    const [fy, fm] = first.split('-').map(Number);
    const [ly, lm] = last.split('-').map(Number);
    return fy === ly ? `${fy}年${fm}月〜${lm}月` : `${fy}年${fm}月〜${ly}年${lm}月`;
  })();

  // 今月承諾者タブ用データ
  const periodKey = period ? period.replace('/', '-') : (() => {
    const n = new Date();
    return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}`;
  })();
  const periodLabel2 = (() => {
    const [y, m] = periodKey.split('-').map(Number);
    return `${y}年${m}月`;
  })();

  const loadMonthlyAccepted = () => {
    try {
      const acc = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const cands = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      const plans = JSON.parse(localStorage.getItem('test-crm-interview-plans') || '{}');
      return acc
        .filter(a => a.assignedCA === CA_MY_NAME)
        .filter(a => {
          const dateStr = a.acceptedAt || a.acceptanceDate || '';
          return dateStr.startsWith(periodKey);
        })
        .map(a => {
          const cand = cands.find(c => c.id === a.id) || {};
          const cpList = plans[a.id] || [];
          const activePlan = cpList.find(cp => !['選考辞退','書類お見送り','面接お見送り'].includes(cp.selectionStatus||'')) || cpList[0] || {};
          const firstInterviewDate = cand.firstInterviewDate || '';
          const acceptedAt = (a.acceptedAt || a.acceptanceDate || '').slice(0,10);
          // リードタイム: 初回面接日 → 承諾日の日数
          let leadTime = null;
          if (firstInterviewDate && acceptedAt) {
            const diff = Math.ceil((new Date(acceptedAt) - new Date(firstInterviewDate.slice(0,10))) / 86400000);
            if (!isNaN(diff) && diff >= 0) leadTime = diff;
          }
          return {
            id: a.id,
            name: a.name || cand.name || '—',
            company: a.companyName || a.company || '—',
            firstInterviewDate: firstInterviewDate.slice(0,10),
            proposalDate: cand.proposalDate || '',
            acceptedAt,
            leadTime,
            joiningDate: a.joiningDate || '',
            jobType: activePlan.jobType || activePlan.position || '',
            revenue: Number(a.contractAmount) || 0,
          };
        });
    } catch { return []; }
  };

  const [monthlyRows, setMonthlyRows] = React.useState(loadMonthlyAccepted);

  React.useEffect(() => {
    setMonthlyRows(loadMonthlyAccepted());
  }, [period]);

  const updateMonthlyRevenue = (id, value) => {
    try {
      const all = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const updated = all.map(a => a.id === id ? { ...a, contractAmount: Number(value) || 0 } : a);
      localStorage.setItem('test-crm-accepted', JSON.stringify(updated));
      setMonthlyRows(loadMonthlyAccepted());
      setAccepted(updated.filter(a => a.assignedCA === CA_MY_NAME).filter(a => {
        const ds = a.acceptedAt || a.acceptanceDate || '';
        return !ds || threeMonths.includes(ds.slice(0,7));
      }));
    } catch {}
  };

  const updateMonthlyJoinDate = (id, value) => {
    try {
      const all = JSON.parse(localStorage.getItem('test-crm-accepted') || '[]');
      const updated = all.map(a => a.id === id ? { ...a, joiningDate: value } : a);
      localStorage.setItem('test-crm-accepted', JSON.stringify(updated));
      setMonthlyRows(loadMonthlyAccepted());
      setAccepted(updated.filter(a => a.assignedCA === CA_MY_NAME).filter(a => {
        const ds = a.acceptedAt || a.acceptanceDate || '';
        return !ds || threeMonths.includes(ds.slice(0,7));
      }));
    } catch {}
  };

  const tabStyle = (tab) => ({
    padding:'8px 24px', borderRadius:'8px 8px 0 0', fontWeight:'700', fontSize:'14px',
    cursor:'pointer', border:'1px solid var(--border)', borderBottom:'none',
    background: activeTab === tab ? 'var(--bg-base)' : 'var(--bg-hover)',
    color: activeTab === tab ? 'var(--accent)' : 'var(--text-muted)',
    transition:'all 0.15s',
  });

  return (
    <div style={{display:'flex', flexDirection:'column', gap:'14px'}}>
      {/* タブ切り替え */}
      <div style={{display:'flex', gap:'4px', borderBottom:'1px solid var(--border)', marginBottom:'-14px'}}>
        <button style={tabStyle('monthly')} onClick={() => setActiveTab('monthly')}>今月承諾者</button>
        <button style={tabStyle('management')} onClick={() => setActiveTab('management')}>承諾管理</button>
      </div>

      {/* ===== 承諾管理タブ ===== */}
      {activeTab === 'management' && (
        <div style={{display:'flex', flexDirection:'column', gap:'14px', paddingTop:'14px'}}>
          {/* 表示期間バナー */}
          <div style={{background:'var(--accent-subtle)',border:'1px solid var(--accent-light)',borderRadius:'var(--radius)',padding:'8px 16px',fontSize:'14px',color:'var(--accent)',display:'flex',alignItems:'center',gap:'8px'}}>
            <span>📅</span>
            <strong>表示期間: {periodLabel}</strong>
            <span style={{color:'var(--text-muted)'}}>— 直近6ヶ月分を表示しています</span>
          </div>
          {/* サマリーKPI */}
          <div className="kpi-grid" style={{gridTemplateColumns:'repeat(3,1fr)'}}>
            <div className="kpi-card" style={{'--kpi-color':'var(--success)'}}>
              <div className="kpi-label">承諾者数</div>
              <div className="kpi-value">{records.length}</div>
              <div className="kpi-target">{periodLabel}</div>
            </div>
            <div className="kpi-card" style={{'--kpi-color':'var(--chart-3)'}}>
              <div className="kpi-label">手続き完了待ち</div>
              <div className="kpi-value">{records.filter(r=>!r.milestones.procedures).length}</div>
              <div className="kpi-target">{records.length}名中</div>
            </div>
            <div className="kpi-card" style={{'--kpi-color':'var(--accent)'}}>
              <div className="kpi-label">入社予定</div>
              <div className="kpi-value">{records.filter(r=>!r.milestones.joinDate).length}</div>
              <div className="kpi-target">{records.length}名中</div>
            </div>
          </div>

          {/* マイルストーン凡例 */}
          <div className="card">
            <div className="card-header">
              <div className="card-title">承諾後フォロー管理</div>
              <div style={{display:'flex', gap:'16px', marginLeft:'auto'}}>
                {ACCEPT_MILESTONES.map(m => (
                  <span key={m.id} style={{fontSize:'15px', color:'var(--text-muted)', display:'flex', alignItems:'center', gap:'4px'}}>
                    <span>{m.icon}</span>{m.label}
                  </span>
                ))}
              </div>
            </div>
            <div className="card-body" style={{padding:'0'}}>
              {records.map((r) => {
                const progress = getProgress(r.id);
                return (
                  <div key={r.id} style={{padding:'16px 20px', borderBottom:'1px solid var(--border)'}}>
                    {/* 上段：名前・情報・進捗円 */}
                    <div style={{display:'grid', gridTemplateColumns:'1fr auto', gap:'12px', alignItems:'start', marginBottom:'12px'}}>
                      <div>
                        <div style={{fontWeight:'700', fontSize:'14px', color:'var(--text-primary)', marginBottom:'4px'}}>{r.name}</div>
                        <div style={{fontSize:'14px', color:'var(--text-muted)', marginBottom:'8px'}}>{r.company}</div>
                        <div style={{display:'grid', gridTemplateColumns:'auto auto 1fr', gap:'12px', alignItems:'center', flexWrap:'wrap'}}>
                          <div>
                            <div style={{fontSize:'12px', color:'var(--text-muted)', marginBottom:'2px'}}>承諾日 <span style={{color:'var(--accent)',fontSize:'11px'}}>（月次集計に反映）</span></div>
                            <input
                              type="date"
                              value={r.acceptDate || ''}
                              onChange={e => updateAcceptDate(r.id, e.target.value)}
                              style={{padding:'3px 8px', border:'1px solid var(--accent-light)', borderRadius:'6px', fontSize:'14px', fontWeight:'600', color:'var(--text-primary)', background:'var(--bg-base)', outline:'none'}}
                            />
                          </div>
                          <div>
                            <div style={{fontSize:'12px', color:'var(--text-muted)', marginBottom:'2px'}}>入社予定日</div>
                            <input
                              type="date"
                              value={r.joinDate && r.joinDate !== '未定' ? r.joinDate : ''}
                              onChange={e => updateJoinDate(r.id, e.target.value)}
                              style={{padding:'3px 8px', border:'1px solid var(--border)', borderRadius:'6px', fontSize:'14px', fontWeight:'600', color:'var(--text-primary)', background:'var(--bg-base)', outline:'none'}}
                            />
                          </div>
                          <div>
                            <div style={{fontSize:'12px', color:'var(--text-muted)', marginBottom:'2px'}}>受注金額</div>
                            <div style={{display:'flex', alignItems:'center', gap:'3px'}}>
                              <span style={{fontSize:'15px', fontWeight:'600', color:'var(--success)'}}>¥</span>
                              <input
                                type="text" inputMode="numeric"
                                value={r.revenue ? r.revenue.toLocaleString() : ''} placeholder="0"
                                onChange={e => updateRevenue(r.id, e.target.value.replace(/[^0-9]/g, ''))}
                                style={{width:'130px', textAlign:'right', padding:'4px 8px', border:'1px solid var(--border)', borderRadius:'6px', fontSize:'15px', fontWeight:'700', color:'var(--success)', background:'var(--bg-base)', outline:'none'}}
                              />
                            </div>
                          </div>
                        </div>
                      </div>
                      {/* 進捗円グラフ + 削除ボタン */}
                      <div style={{display:'flex', flexDirection:'column', alignItems:'center', gap:'6px'}}>
                        <div style={{
                          width:'52px', height:'52px', borderRadius:'50%',
                          background:`conic-gradient(var(--accent) ${progress}%, var(--bg-hover) 0)`,
                          display:'flex', alignItems:'center', justifyContent:'center',
                          fontSize:'14px', fontWeight:'700', color:'var(--text-primary)',
                        }}>{progress}%</div>
                        <div style={{fontSize:'12px', color:'var(--text-muted)'}}>進捗</div>
                        <button onClick={() => deleteAccepted(r.id, r.name)}
                          style={{fontSize:'12px', padding:'3px 10px', border:'1px solid var(--danger)', borderRadius:'4px',
                            background:'var(--danger-bg)', color:'var(--danger)', cursor:'pointer', fontWeight:'600', marginTop:'2px'}}>
                          削除
                        </button>
                      </div>
                    </div>
                    {/* 下段：マイルストーンボタン（5列グリッド） */}
                    <div style={{display:'grid', gridTemplateColumns:'repeat(5,1fr)', gap:'8px'}}>
                      {ACCEPT_MILESTONES.map((m) => {
                        const done = r.milestones[m.id];
                        const isFirst = m.id === 'accepted';
                        return (
                          <button key={m.id} onClick={() => toggleMilestone(r.id, m.id)} disabled={isFirst}
                            style={{
                              display:'flex', flexDirection:'column', alignItems:'center', gap:'4px',
                              padding:'10px 6px', borderRadius:'10px',
                              border: done ? '1.5px solid var(--success)' : '1.5px solid var(--border)',
                              cursor: isFirst ? 'default' : 'pointer',
                              background: done ? 'rgba(16,185,129,0.08)' : 'var(--bg-base)',
                              color: done ? 'var(--success)' : 'var(--text-muted)',
                              fontWeight: done ? '700' : '400',
                              fontSize:'13px', transition:'all 0.15s',
                              opacity: isFirst ? 1 : 1,
                            }}
                          >
                            <span style={{fontSize:'16px'}}>{done ? '✅' : m.icon}</span>
                            <span style={{textAlign:'center', lineHeight:'1.3'}}>{m.label}</span>
                          </button>
                        );
                      })}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* ===== 今月承諾者タブ ===== */}
      {activeTab === 'monthly' && (
        <div style={{display:'flex', flexDirection:'column', gap:'14px', paddingTop:'14px'}}>
          {/* バナー */}
          <div style={{background:'var(--accent-subtle)',border:'1px solid var(--accent-light)',borderRadius:'var(--radius)',padding:'8px 16px',fontSize:'14px',color:'var(--accent)',display:'flex',alignItems:'center',gap:'8px'}}>
            <span>🎉</span>
            <strong>{periodLabel2}の承諾者一覧</strong>
            <span style={{color:'var(--text-muted)'}}>— {monthlyRows.length}名</span>
          </div>

          {/* テーブル */}
          <div className="card">
            <div className="card-body" style={{padding:'0', overflowX:'auto'}}>
              {monthlyRows.length === 0 ? (
                <div style={{padding:'32px', textAlign:'center', color:'var(--text-muted)', fontSize:'14px'}}>
                  {periodLabel2}の承諾者はまだいません
                </div>
              ) : (
                <table style={{width:'100%', borderCollapse:'collapse', fontSize:'14px'}}>
                  <thead>
                    <tr style={{background:'var(--bg-hover)', borderBottom:'2px solid var(--border)'}}>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>求職者氏名</th>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>承諾先企業</th>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>初回面接日</th>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>提案日</th>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>承諾日</th>
                      <th style={{padding:'10px 14px', textAlign:'center', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>リードタイム</th>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>入社日</th>
                      <th style={{padding:'10px 14px', textAlign:'left', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>職種</th>
                      <th style={{padding:'10px 14px', textAlign:'right', fontWeight:'700', color:'var(--text-muted)', whiteSpace:'nowrap'}}>受注額</th>
                    </tr>
                  </thead>
                  <tbody>
                    {monthlyRows.map((row, idx) => (
                      <tr key={row.id} style={{borderBottom:'1px solid var(--border)', background: idx % 2 === 0 ? 'var(--bg-base)' : 'var(--bg-hover)'}}>
                        <td style={{padding:'10px 14px', fontWeight:'700', color:'var(--text-primary)', whiteSpace:'nowrap'}}>{row.name}</td>
                        <td style={{padding:'10px 14px', color:'var(--text-secondary)', whiteSpace:'nowrap'}}>{row.company}</td>
                        <td style={{padding:'10px 14px', color:'var(--text-secondary)', whiteSpace:'nowrap'}}>{row.firstInterviewDate || '—'}</td>
                        <td style={{padding:'10px 14px', color:'var(--text-secondary)', whiteSpace:'nowrap'}}>{row.proposalDate ? row.proposalDate.slice(0,10) : '—'}</td>
                        <td style={{padding:'10px 14px', color:'var(--accent)', fontWeight:'600', whiteSpace:'nowrap'}}>{row.acceptedAt || '—'}</td>
                        <td style={{padding:'10px 14px', textAlign:'center', whiteSpace:'nowrap'}}>
                          {row.leadTime !== null
                            ? <span style={{background:'var(--accent-subtle)',color:'var(--accent)',fontWeight:'700',padding:'2px 10px',borderRadius:'12px',fontSize:'13px'}}>{row.leadTime}日</span>
                            : <span style={{color:'var(--text-muted)'}}>—</span>}
                        </td>
                        <td style={{padding:'10px 14px'}}>
                          <input
                            type="date"
                            value={row.joiningDate || ''}
                            onChange={e => updateMonthlyJoinDate(row.id, e.target.value)}
                            style={{padding:'3px 8px', border:'1px solid var(--border)', borderRadius:'6px', fontSize:'13px', fontWeight:'600', color:'var(--text-primary)', background:'var(--bg-base)', outline:'none'}}
                          />
                        </td>
                        <td style={{padding:'10px 14px', color:'var(--text-secondary)', whiteSpace:'nowrap'}}>{row.jobType || '—'}</td>
                        <td style={{padding:'10px 14px', textAlign:'right'}}>
                          <div style={{display:'flex', alignItems:'center', justifyContent:'flex-end', gap:'3px'}}>
                            <span style={{fontWeight:'600', color:'var(--success)'}}>¥</span>
                            <input
                              type="text" inputMode="numeric"
                              value={row.revenue ? row.revenue.toLocaleString() : ''} placeholder="0"
                              onChange={e => updateMonthlyRevenue(row.id, e.target.value.replace(/[^0-9]/g, ''))}
                              style={{width:'120px', textAlign:'right', padding:'4px 8px', border:'1px solid var(--border)', borderRadius:'6px', fontSize:'14px', fontWeight:'700', color:'var(--success)', background:'var(--bg-base)', outline:'none'}}
                            />
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                  <tfoot>
                    <tr style={{borderTop:'2px solid var(--border)', background:'var(--accent-subtle)'}}>
                      <td colSpan="8" style={{padding:'10px 14px', fontWeight:'700', color:'var(--text-primary)'}}>合計受注額</td>
                      <td style={{padding:'10px 14px', textAlign:'right', fontWeight:'700', color:'var(--success)', fontSize:'15px'}}>
                        ¥{monthlyRows.reduce((s,r)=>s+r.revenue,0).toLocaleString()}
                      </td>
                    </tr>
                  </tfoot>
                </table>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

function TrendPage() {
  const loadTrend = () => {
    try {
      const stored = JSON.parse(localStorage.getItem('test-crm-candidates') || '[]');
      const mine = Array.isArray(stored) ? stored.filter(c => c.assignedCA === CA_MY_NAME) : [];
      const now = new Date();
      const months = [];
      for (let i = 5; i >= 0; i--) {
        const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
        months.push({
          key: `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`,
          label: `${d.getMonth()+1}月`,
        });
      }
      return {
        labels:   months.map(m => m.label),
        apps:     months.map(m => mine.filter(c => (c.createdAt||'').startsWith(m.key)).length),
        firstInt: months.map(m => mine.filter(c => (c.firstInterviewDate||'').startsWith(m.key)).length),
        accepted: months.map(m => mine.filter(c =>
          ['承諾'].includes(c.caStatus || c.status || '') &&
          ((c.acceptanceDate || c.createdAt || '').startsWith(m.key))
        ).length),
      };
    } catch { return { labels:[], apps:[], firstInt:[], accepted:[] }; }
  };

  const [trend, setTrend] = React.useState(loadTrend);
  React.useEffect(() => {
    const reload = () => setTrend(loadTrend());
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, []);

  return (
    <div style={{display:'flex', flexDirection:'column', gap:'14px'}}>
      <div className="card">
        <div className="card-header">
          <div className="card-title">月別推移分析</div>
          <div className="card-subtitle" style={{marginLeft:'auto'}}>過去6ヶ月（実データ集計）</div>
        </div>
        <div className="card-body">
          {trend.labels.length === 0
            ? <div className="empty-state">候補者データがありません</div>
            : <LineChart
                datasets={[
                  { label: '面接設定', data: trend.firstInt },
                  { label: '承諾',    data: trend.accepted },
                ]}
                labels={trend.labels}
                height={220}
              />
          }
        </div>
      </div>
      <div style={{display:'grid', gridTemplateColumns:'repeat(2,1fr)', gap:'12px'}}>
        {[
          { label: '面接設定（累計）', value: trend.firstInt.reduce((s,v)=>s+v,0), color:'var(--chart-2)' },
          { label: '承諾（累計）',    value: trend.accepted.reduce((s,v)=>s+v,0), color:'var(--success)'  },
        ].map((item, i) => (
          <div key={i} className="kpi-card" style={{'--kpi-color':item.color}}>
            <div className="kpi-label">{item.label}</div>
            <div className="kpi-value">{item.value}</div>
            <div className="kpi-target">過去6ヶ月合計</div>
          </div>
        ))}
      </div>
    </div>
  );
}

// ====== MAIN APP ======
function App() {
  const [theme, setTheme] = useState(() => localStorage.getItem('crm-theme') || 'minimal-light');
  const [page, setPage] = useState('summary');
  // 月選択オプション（過去12ヶ月〜翌月）
  const periodOptions = useMemo(() => {
    const opts = [];
    const now = new Date();
    for (let i = -12; i <= 1; i++) {
      const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
      const val = `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}`;
      opts.push(val);
    }
    return opts.reverse();
  }, []);
  const defaultPeriod = `${new Date().getFullYear()}/${String(new Date().getMonth()+1).padStart(2,'0')}`;
  const [selectedPeriod, setSelectedPeriod] = useState(defaultPeriod);
  const todayStr = (() => {
    const d = new Date();
    return `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')} (${['日','月','火','水','木','金','土'][d.getDay()]})`;
  })();

  useEffect(() => {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('crm-theme', theme);
  }, [theme]);

  const renderPage = () => {
    switch (page) {
      case 'summary':    return <SummaryPage period={selectedPeriod} />;
      case 'progress':   return <ProgressPage period={selectedPeriod} />;
      case 'revenue':    return <RevenuePage period={selectedPeriod} />;
      case 'interviews': return <InterviewsPage />;
      case 'candidates': return <CandidatesPage />;
      case 'actions':    return <ActionsPage />;
      case 'postAccept': return <PostAcceptPage period={selectedPeriod} />;
      case 'trend':      return <TrendPage />;
      default:           return <SummaryPage period={selectedPeriod} />;
    }
  };

  const pageTitle = NAV_ITEMS.find(n => n.id === page)?.label || 'サマリー';

  return (
    <div className="app-layout">
      <aside className="sidebar">
        <div className="sidebar-logo">
          <h1>CA CRM</h1>
          <p>人材紹介管理システム</p>
        </div>
        <nav className="sidebar-nav">
          <div className="nav-section-label">メインメニュー</div>
          {NAV_ITEMS.map(item => (
            <div key={item.id} className={`nav-item ${page === item.id ? 'active' : ''}`}
              onClick={() => setPage(item.id)}>
              <span className="nav-icon">{NAV_ICONS[item.id]}</span>
              {item.label}
            </div>
          ))}
          <div className="separator" style={{margin:'12px 0'}} />
          <div className="nav-item" onClick={() => window.location.href='admin.html'} style={{opacity:0.7}}>
            <span className="nav-icon">{NAV_ICONS.admin}</span>
            管理者画面へ
          </div>
        </nav>
        <div className="sidebar-footer">v2.0 · {CA_MY_NAME}</div>
      </aside>
      <div className="main-content">
        <div className="topbar">
          <div className="topbar-left">
            <div>
              <div className="page-title">{pageTitle}</div>
              <div className="page-subtitle">{todayStr} · {CA_MY_NAME}</div>
            </div>
            <select
              value={selectedPeriod}
              onChange={e=>setSelectedPeriod(e.target.value)}
              style={{
                fontSize:'14px',fontWeight:'600',color:'var(--text-secondary)',
                background:'var(--bg-base)',border:'1px solid var(--border)',
                borderRadius:'var(--radius-sm)',padding:'3px 8px',cursor:'pointer',
                outline:'none',
              }}
            >
              {periodOptions.map(p=>(
                <option key={p} value={p}>{p}</option>
              ))}
            </select>
          </div>
          <div className="topbar-right">
            <ThemeSwitcher theme={theme} setTheme={setTheme} />
            <div
              title="ログアウト"
              onClick={() => { if(window.confirm('ログアウトしますか？')) _auth.signOut(); }}
              style={{
                width:'32px', height:'32px', borderRadius:'50%',
                background:'var(--accent)', color:'#fff',
                display:'flex', alignItems:'center', justifyContent:'center',
                fontSize:'15px', fontWeight:'700', cursor:'pointer'
              }}>{CA_MY_NAME[0] || '?'}</div>
          </div>
        </div>
        <div className="content-area">
          {renderPage()}
        </div>
      </div>
    </div>
  );
}


