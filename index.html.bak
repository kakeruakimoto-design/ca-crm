        {id:'s003',name:'サンプル03',assignedCA:'テストCA',contractAmount:350000,acceptedAt:'2026-05-13',company:'企業C',joiningDate:'2026-06-16'},
        {id:'s004',name:'サンプル04',assignedCA:'テストCA',contractAmount:400000,acceptedAt:'2026-05-14',company:'企業D',joiningDate:'2026-06-01'},
        {id:'a003',name:'テスト③',assignedCA:'テストCA',contractAmount:350000,acceptedAt:'2026-05-05',company:'企業γ',joiningDate:'2026-06-01'},
        // 4月承諾（4月中に承諾完了）
        {id:'b001',name:'テスト④',assignedCA:'テストCA',contractAmount:350000,acceptedAt:'2026-04-20',company:'企業P',joiningDate:'2026-06-01',postAcceptMeetingDate:'2026-04-25',procedureCompleteDate:'2026-05-02'},
        {id:'b002',name:'テスト⑤',assignedCA:'テストCA',contractAmount:400000,acceptedAt:'2026-04-25',company:'企業Q',joiningDate:'2026-06-01',postAcceptMeetingDate:'2026-04-30',procedureCompleteDate:'2026-05-07'},
      ]));
    }

    // ========== 企業面接スケジュール（selectionStatus は画面の選択肢と一致させる）==========
    // 有効値: 書類選考中/一次面接/二次面接/最終面接/選考結果待ち/オファー面談/内定/内定承諾/入社確定/選考辞退/書類お見送り/面接お見送り
    if (!localStorage.getItem('test-crm-interview-plans')) {
      localStorage.setItem('test-crm-interview-plans', JSON.stringify({
        // 承諾済み（入社準備中）
        's001': [{company:'企業A',jobType:'営業',date:'2026-05-11',selectionStatus:'入社確定'}],
        's002': [{company:'企業B',jobType:'営業',date:'2026-05-12',selectionStatus:'内定承諾'}],
        's003': [{company:'企業C',jobType:'営業',date:'2026-05-13',selectionStatus:'入社確定'}],
        's004': [{company:'企業D',jobType:'営業',date:'2026-05-14',selectionStatus:'内定承諾'}],
        // 内定（承諾検討中）
        's005': [{company:'企業E',jobType:'営業',date:'2026-05-14',selectionStatus:'内定',offerDeadline:'2026-05-20'}],
        // 企業面接（一次面接予定）
        's006': [{company:'企業F',jobType:'営業',date:'2026-05-19',selectionStatus:'一次面接',pendingConfirm:false,offerDeadline:''}],
        's007': [{company:'企業G',jobType:'営業',date:'2026-05-21',selectionStatus:'一次面接',pendingConfirm:false,offerDeadline:''}],
        // 推薦（書類選考中）
        's008': [{company:'企業H',jobType:'営業',date:'2026-05-20',selectionStatus:'書類選考中'}],
        // 企業提案（書類選考中）
        's009': [{company:'企業I',jobType:'営業',date:'',selectionStatus:'書類選考中'}],
        's010': [{company:'企業J',jobType:'営業',date:'',selectionStatus:'書類選考中'}],
        // 持ち越し候補者
        'a001': [{company:'企業α',jobType:'営業',date:'2026-05-16',selectionStatus:'一次面接',pendingConfirm:true,offerDeadline:''}],
        'a002': [{company:'企業β',jobType:'営業',date:'2026-05-08',selectionStatus:'内定',offerDeadline:'2026-05-20'}],
        'a003': [{company:'企業γ',jobType:'営業',date:'2026-05-05',selectionStatus:'入社確定'}],
        // 4月承諾済み
        'b001': [{company:'企業P',jobType:'営業',date:'2026-04-20',selectionStatus:'入社確定'}],
        'b002': [{company:'企業Q',jobType:'営業',date:'2026-04-25',selectionStatus:'入社確定'}],
        // 4月内定（承諾検討中）
        'b003': [{company:'企業R',jobType:'営業',date:'2026-04-25',selectionStatus:'内定',offerDeadline:'2026-05-16'}],
        'b004': [{company:'企業S',jobType:'営業',date:'2026-04-28',selectionStatus:'内定'}],
        // 4月企業面接（選考中）
        'b005': [{company:'企業T',jobType:'営業',date:'2026-05-12',selectionStatus:'最終面接'}],
        'b006': [{company:'企業U',jobType:'営業',date:'2026-05-08',selectionStatus:'選考結果待ち'}],
        'b007': [{company:'企業V',jobType:'営業',date:'',selectionStatus:'書類選考中'}],
        // 4月推薦（書類選考中）
        'b008': [{company:'企業W',jobType:'営業',date:'',selectionStatus:'書類選考中'}],
        'b009': [{company:'企業X',jobType:'営業',date:'',selectionStatus:'書類選考中'}],
        'b010': [{company:'企業Y',jobType:'営業',date:'',selectionStatus:'書類選考中'}],
      }));
    }

    // ========== 企業面接管理メタ（見込み・他社選考・他エージェント）==========
    if (!localStorage.getItem('test-crm-candidate-meta')) {
      localStorage.setItem('test-crm-candidate-meta', JSON.stringify({
        's001': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        's002': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        's003': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        's004': {rank:'100%', hasOtherSelection:'あり', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        's005': {rank:'100%', hasOtherSelection:'あり', hasAgent:'あり', desiredJoinMonth:'2026-06'},
        's006': {rank:'70%',  hasOtherSelection:'あり', hasAgent:'あり', desiredJoinMonth:'2026-07'},
        's007': {rank:'70%',  hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        's008': {rank:'50%',  hasOtherSelection:'あり', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        // s009・s010 は企業提案（推薦前）なので見込みランクなし
        's009': {hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        's010': {hasOtherSelection:'あり', hasAgent:'あり', desiredJoinMonth:'2026-08'},
        // s011・s012 はブリッジ成功（推薦前）なので見込みランクなし
        's011': {hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        's012': {hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-08'},
        // 持ち越し候補者（見込みランクあり）
        'a001': {rank:'70%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        'a002': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        'a003': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        // 4月承諾済み
        'b001': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        'b002': {rank:'100%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        // 4月内定（承諾検討中）
        'b003': {rank:'70%', hasOtherSelection:'あり', hasAgent:'あり', desiredJoinMonth:'2026-06'},
        'b004': {rank:'70%', hasOtherSelection:'あり', hasAgent:'なし', desiredJoinMonth:'2026-06'},
        // 4月企業面接（選考中）
        'b005': {rank:'70%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        'b006': {rank:'50%', hasOtherSelection:'あり', hasAgent:'あり', desiredJoinMonth:'2026-07'},
        'b007': {rank:'50%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        // 4月推薦（見込みランク設定済み）
        'b008': {rank:'50%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
        'b009': {rank:'50%', hasOtherSelection:'あり', hasAgent:'なし', desiredJoinMonth:'2026-08'},
        'b010': {rank:'50%', hasOtherSelection:'なし', hasAgent:'なし', desiredJoinMonth:'2026-07'},
      }));
    }

      setReady(true);
    }
    init();
  }, []);
  if (!ready) return <div style={{minHeight:'100vh',display:'flex',alignItems:'center',justifyContent:'center',fontSize:'18px',color:'#6b7280'}}>読み込み中...</div>;
  return <App />;
}
ReactDOM.createRoot(document.getElementById('root')).render(<Root />);

</script>
</body>