function SummaryPage({ period }) {
  const [metrics, setMetrics] = React.useState(() => _loadMyMetrics(period));
  React.useEffect(() => {
    setMetrics(_loadMyMetrics(period)); // 月変更時に即時更新
    const reload = () => setMetrics(_loadMyMetrics(period));
    window.addEventListener('focus', reload);
    return () => window.removeEventListener('focus', reload);
  }, [period]);
  const MY_KPI = metrics.kpi;
  const STAGE_PROGRESS = metrics.stageProgress;
  const RATE_KPIS = metrics.rateKpis;
  const FUNNEL_DATA = metrics.funnelData;
  const MY_REVENUE = metrics.revenue || { current: 0, target: 3000000, requiredByToday: 0 };

  const [summaryData, setSummaryData] = React.useState(_loadSummaryData);
  React.useEffect(() => {
    const reloadS = () => setSummaryData(_loadSummaryData());
    window.addEventListener('focus', reloadS);
    return () => window.removeEventListener('focus', reloadS);
  }, []);
  const { interviewsFirstToday: INTERVIEWS_FIRST_TODAY, interviewsToday: INTERVIEWS_TODAY,
    interviewsUpcoming: INTERVIEWS_UPCOMING, pendingReply: PENDING_REPLY,
    proposalCandidates, actions: ACTIONS } = summaryData;

  const revenueRate = pct(MY_REVENUE.current, MY_REVENUE.target);
  const revenueColor = revenueRate >= 90 ? 'var(--success)' : revenueRate >= 60 ? 'var(--warning)' : 'var(--danger)';
  const now = new Date();
  // period "2026/05" → year/month、なければ今月
  const [selY, selM] = period ? period.split('/').map(Number) : [now.getFullYear(), now.getMonth()+1];
  const daysInMonth = new Date(selY, selM, 0).getDate();
  const isCurrentMonth = selY === now.getFullYear() && selM === (now.getMonth()+1);
  const dayOfMonth = isCurrentMonth ? now.getDate() : daysInMonth;
  const monthProgressPct = Math.round(dayOfMonth / daysInMonth * 100);
  return (
    <div style={{display:'flex', flexDirection:'column', gap:'14px'}}>
      {/* 月次進捗バナー */}
      <div style={{
        background:'var(--accent-subtle)', border:'1px solid var(--accent-light)',
        borderRadius:'var(--radius)', padding:'10px 16px',
        display:'flex', alignItems:'center', gap:'12px', flexWrap:'wrap'
      }}>
        <span style={{fontSize:'15px', fontWeight:'700', color:'var(--accent)'}}>{selM}月 月次進捗</span>
        <div style={{flex:'1',minWidth:'120px',height:'8px',background:'var(--border)',borderRadius:'4px',overflow:'hidden'}}>
          <div style={{width:`${monthProgressPct}%`,height:'100%',background:'var(--accent)',borderRadius:'4px',transition:'width 0.4s'}}/>
        </div>
        <span style={{fontSize:'15px', fontWeight:'700', color:'var(--accent)', minWidth:'36px'}}>{monthProgressPct}%</span>
        <span style={{fontSize:'14px', color:'var(--text-muted)'}}>{daysInMonth}日中{dayOfMonth}日経過</span>
      </div>

      {/* Row 0: 受注金額・達成率バナー（3枚） */}
      <div style={{display:'grid', gridTemplateColumns:'1fr 1fr 1fr', gap:'10px'}}>
        <div className="kpi-card" style={{'--kpi-color':'var(--chart-1)'}}>
          <div className="kpi-label">受注金額</div>
          <div className="kpi-value" style={{fontSize:'22px'}}>{fmtYen(MY_REVENUE.current)}</div>
          <div className="kpi-target">目標: {fmtYen(MY_REVENUE.target)}</div>
        </div>
        <div className="kpi-card" style={{'--kpi-color':revenueColor}}>
          <div className="kpi-label">達成率</div>
          <div className="kpi-value" style={{fontSize:'28px', color:revenueColor}}>{revenueRate}%</div>
          <div className="kpi-target">本日必要額: {fmtYen(MY_REVENUE.requiredByToday)}</div>
        </div>
        <div className="kpi-card" style={{'--kpi-color':'var(--chart-3)'}}>
          <div className="kpi-label">承諾数</div>
          <div className="kpi-value">{MY_KPI.acceptance.value}</div>
          <div className="kpi-target">目標: {MY_KPI.acceptance.target}件</div>
        </div>
      </div>

      {/* Row 1: Interviews (4列) */}
      <div style={{display:'grid', gridTemplateColumns:'repeat(4,1fr)', gap:'14px'}}>
        <div className="card">
          <div className="card-header">
            <div className="card-title">本日の初回面接</div>
            <span className="badge-count" style={{background:'var(--chart-2)'}}>{INTERVIEWS_FIRST_TODAY.length}</span>
          </div>
          <div className="card-body">
            {INTERVIEWS_FIRST_TODAY.length === 0
              ? <div className="empty-state">本日の初回面接なし</div>
              : INTERVIEWS_FIRST_TODAY.map((iv, i) => (
                <div key={i} className="interview-item">
                  <div className="interview-dot" style={{background:'var(--chart-2)'}} />
                  <div>
                    <div className="interview-name">{iv.name}</div>
                    <div className="interview-meta">{iv.time} · {iv.type}</div>
                  </div>
                </div>
              ))}
          </div>
        </div>
        <div className="card">
          <div className="card-header">
            <div className="card-title">本日の企業面接</div>
            <span className="badge-count" style={{background:'var(--danger)'}}>{INTERVIEWS_TODAY.length}</span>
          </div>
          <div className="card-body">
            {INTERVIEWS_TODAY.length === 0
              ? <div className="empty-state">本日の面接なし</div>
              : INTERVIEWS_TODAY.map((iv, i) => (
                <div key={i} className="interview-item">
                  <div className="interview-dot" style={{background:'var(--danger)'}} />
                  <div>
                    <div className="interview-name">{iv.name}</div>
                    <div className="interview-meta">{iv.company} · {iv.time} · {iv.type}</div>
                  </div>
                </div>
              ))}
          </div>
        </div>
        <div className="card">
          <div className="card-header">
            <div className="card-title">今後の面接予定</div>
            <span className="badge-count">{INTERVIEWS_UPCOMING.length}</span>
          </div>
          <div className="card-body">
            {(() => {
              const tomorrowFmt = new Date(Date.now() + 86400000).toISOString().slice(5,10).replace('-','/');
              return INTERVIEWS_UPCOMING.map((iv, i) => {
                const isTomorrow = iv.date === tomorrowFmt;
                return (
                  <div key={i} className="interview-item" style={isTomorrow ? {
                    background:'#fff7ed', borderLeft:'3px solid #f97316',
                    borderRadius:'6px', paddingLeft:'8px', marginBottom:'4px'
                  } : {}}>
                    <div className="interview-dot" style={{background: isTomorrow ? '#f97316' : 'var(--accent)'}} />
                    <div>
                      <div className="interview-name" style={isTomorrow ? {color:'#c2410c', fontWeight:'700'} : {}}>{iv.name}</div>
                      <div className="interview-meta" style={isTomorrow ? {color:'#ea580c'} : {}}>{iv.company} · {iv.date} · {iv.type}</div>
                    </div>
                  </div>
                );
              });
            })()}
          </div>
        </div>
        <div className="card">
          <div className="card-header">
            <div className="card-title">面接確定返信待ち</div>
            <span className="badge-count" style={{background:'var(--warning)'}}>{PENDING_REPLY.length}</span>
          </div>
          <div className="card-body">
            {PENDING_REPLY.map((p, i) => (
              <div key={i} className="interview-item">
                <div className="interview-dot" style={{background: p.urgent ? 'var(--danger)' : 'var(--warning)'}} />
                <div>
                  <div className="interview-name">{p.name}</div>
                  <div className="interview-meta" style={{color: p.urgent ? 'var(--danger)' : undefined}}>{p.memo}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Row 4: Proposals + Actions */}
      <div className="grid-2">
        <div className="card">
          <div className="card-header">
            <div className="card-title">📋 企業提案中</div>
            <span className="badge-count">{proposalCandidates.length}</span>
          </div>
          <div className="card-body" style={{maxHeight:'180px', overflowY:'auto'}}>
            {proposalCandidates.length === 0
              ? <div className="empty-state">提案中の候補者なし</div>
              : proposalCandidates.map((c, i) => (
              <div key={i} className="interview-item">
                <div className="interview-dot" style={{background: getStatusColor(c.caStatus || c.status)}} />
                <div style={{flex:1}}>
                  <div style={{display:'flex', justifyContent:'space-between'}}>
                    <div className="interview-name">{c.name}</div>
                    <StatusBadge status={c.caStatus || c.status} />
                  </div>
                  <div className="interview-meta">{c._propCompany} · {c._propDate || '—'}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div className="card">
          <div className="card-header">
            <div className="card-title">✅ 対応事項</div>
            <span className="badge-count" style={{background:'var(--danger)'}}>{ACTIONS.filter(a=>a.urgent).length}</span>
          </div>
          <div className="card-body">
            {ACTIONS.map((a, i) => (
              <div key={i} className="action-item">
                <span className="action-priority" style={{
                  background: a.priority==='高' ? 'var(--danger-bg)' : a.priority==='中' ? 'var(--warning-bg)' : 'var(--info-bg)',
                  color: a.priority==='高' ? 'var(--danger)' : a.priority==='中' ? 'var(--warning)' : 'var(--info)',
                }}>{a.priority}</span>
                <div>
                  <div className="action-text">{a.text}</div>
                  <div className="action-due">{a.due}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  );
}

